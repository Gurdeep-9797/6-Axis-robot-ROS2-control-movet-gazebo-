<Window x:Class="RoboForge.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:local="clr-namespace:RoboForge.Wpf"
        xmlns:converters="clr-namespace:RoboForge.Wpf.Converters"
        xmlns:vm="clr-namespace:RoboForge.Wpf.ViewModels"
        Title="RoboForge v8.2 — Offline Industrial Robot IDE"
        Width="1400" Height="900"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Enum to Bool Converter for Radio Buttons -->
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
        
        <!-- Status Color Converter -->
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        
        <!-- Bool to Color Converter -->
        <converters:BoolToColorConverter x:Key="BoolToColor"/>
    </Window.Resources>

    <!-- Main 4-Column Grid Layout -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <!-- Left: Program Tree -->
            <ColumnDefinition Width="*"/>
            <!-- Center: 3D Viewport -->
            <ColumnDefinition Width="4"/>
            <!-- Resizer -->
            <ColumnDefinition Width="320"/>
            <!-- Right: Properties + Jog -->
        </Grid.ColumnDefinitions>

        <!-- ==================== LEFT PANEL: PROGRAM TREE ==================== -->
        <Border Grid.Column="0" Background="#252536" BorderBrush="#3A3A4A" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- Program Tree -->
                    <RowDefinition Height="Auto"/>
                    <!-- Execution Controls -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#2D2D3F" Padding="12,0">
                    <TextBlock Text="📋 PROGRAM TREE" Foreground="#8888A0" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Segoe UI"/>
                </Border>

                <!-- Program Blocks List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl ItemsSource="{Binding ProgramBlocks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Padding="8,6" CornerRadius="4"
                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                        BorderBrush="Transparent" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Type Icon -->
                                        <TextBlock Width="20" FontSize="10" VerticalAlignment="Center"
                                                   Text="{Binding Type, StringFormat='{}[{0}]'}"
                                                   Foreground="#A0A0B8" FontWeight="Bold"/>
                                        <!-- Name -->
                                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
                                                   Text="{Binding Name}" Foreground="#E8E8F0"
                                                   FontSize="11" FontFamily="Consolas"/>
                                        <!-- Status Dot -->
                                        <Ellipse Width="8" Height="8" Margin="8,0,0,0" VerticalAlignment="Center"
                                                 Fill="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Execution Controls -->
                <Border Grid.Row="2" Background="#2D2D3F" Padding="8" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Vertical">
                        <StackPanel.Children>
                            <!-- Run/Stop/Pause -->
                            <UniformGrid Columns="3" Height="32" Margin="0,0,0,6">
                                <Button Content="▶ Run" Command="{Binding RunCommand}"
                                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                                        FontSize="11" FontWeight="SemiBold" Margin="1"/>
                                <Button Content="⏸ Pause" Command="{Binding PauseCommand}"
                                        Background="#F57C00" Foreground="White" BorderThickness="0"
                                        FontSize="11" FontWeight="SemiBold" Margin="1"/>
                                <Button Content="⏹ Stop" Command="{Binding StopCommand}"
                                        Background="#C62828" Foreground="White" BorderThickness="0"
                                        FontSize="11" FontWeight="SemiBold" Margin="1"/>
                            </UniformGrid>

                            <!-- Mode Toggles -->
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Edit" IsChecked="{Binding ActiveMode, Converter={StaticResource EnumToBool}, ConverterParameter=Edit}"
                                             GroupName="Mode" Foreground="#A0A0B8" FontSize="10" Padding="4,2"/>
                                <RadioButton Content="Sim" IsChecked="{Binding ActiveMode, Converter={StaticResource EnumToBool}, ConverterParameter=Simulate}"
                                             GroupName="Mode" Foreground="#A0A0B8" FontSize="10" Padding="4,2" Margin="4,0"/>
                                <RadioButton Content="Live" IsChecked="{Binding ActiveMode, Converter={StaticResource EnumToBool}, ConverterParameter=Live}"
                                             GroupName="Mode" Foreground="#A0A0B8" FontSize="10" Padding="4,2"/>
                            </StackPanel>
                        </StackPanel.Children>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ==================== CENTER PANEL: 3D VIEWPORT ==================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <!-- Toolbar -->
                <RowDefinition Height="*"/>
                <!-- 3D Viewport -->
                <RowDefinition Height="200"/>
                <!-- Console -->
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#2D2D3F" Padding="12,0" BorderBrush="#3A3A4A" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎮 3D VIEWPORT" Foreground="#8888A0" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- Connection Status -->
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding IsRos2Connected, Converter={StaticResource BoolToColor}}"/>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="#A0A0B8"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- IK Mode -->
                    <TextBlock Text="IK:" Foreground="#8888A0" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <RadioButton Content="Numerical" IsChecked="{Binding IkMode, Converter={StaticResource EnumToBool}, ConverterParameter=Numerical}"
                                 GroupName="IK" Foreground="#A0A0B8" FontSize="10" Padding="4,2" Margin="0,0,8,0"/>
                    <RadioButton Content="Analytical" IsChecked="{Binding IkMode, Converter={StaticResource EnumToBool}, ConverterParameter=Analytical}"
                                 GroupName="IK" Foreground="#A0A0B8" FontSize="10" Padding="4,2" Margin="0,0,16,0"/>

                    <!-- Motor Speed -->
                    <TextBlock Text="PWM:" Foreground="#8888A0" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider Width="80" Minimum="0" Maximum="100" Value="{Binding MotorSpeed}"
                            Background="#3A3A4A" Foreground="#4A90D9"/>
                    <TextBlock Text="{Binding MotorSpeed, StringFormat='{}{0}%'}" Foreground="#A0A0B8"
                               FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- HelixToolkit 3D Viewport -->
            <hx:Viewport3DX Grid.Row="1" Background="#1A1A2E" UseDefaultGestures="True"
                            ShowViewCube="True" ShowCoordinateSystem="True"
                            CameraMode="Inspect" CameraRotationMode="TurnTable">
                <hx:Viewport3DX.Camera>
                    <hx:PerspectiveCamera Position="3,2,2.5" LookDirection="-3,-2,-1.5" UpDirection="0,0,1"
                                          FarPlaneDistance="100" NearPlaneDistance="0.01"
                                          FieldOfView="45"/>
                </hx:Viewport3DX.Camera>

                <!-- Lighting -->
                <hx:Viewport3DX.Items>
                    <hx:AmbientLight3D Color="#404060"/>
                    <hx:DirectionalLight3D Direction="1,-1,-1" Color="#FFFFFF"/>
                    <hx:DirectionalLight3D Direction="-1,1,-0.5" Color="#8080A0"/>
                    <!-- [QWEN TODO] Add robot mesh via code-behind loading URDF -->
                </hx:Viewport3DX.Items>
            </hx:Viewport3DX>

            <!-- Console Output -->
            <Border Grid.Row="2" Background="#252536" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2D2D3F" Padding="8,0">
                        <TextBlock Text="🖥 CONSOLE" Foreground="#8888A0" FontSize="10"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding ConsoleEntries}"
                             Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" FontSize="10" Padding="4"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Time}" Foreground="#606078" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Level}" Width="32" Margin="0,0,8,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#A0A0B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="OK">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="WRN">
                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="ERR">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Message}" Foreground="#C8C8E0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Resizer Handle -->
        <GridSplitter Grid.Column="2" Width="4" Background="#3A3A4A"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- ==================== RIGHT PANEL: PROPERTIES + JOG ==================== -->
        <Border Grid.Column="3" Background="#252536" BorderBrush="#3A3A4A" BorderThickness="1,0,0,0">
            <TabControl Background="Transparent" BorderThickness="0">
                <!-- Tab 1: Properties -->
                <TabItem Header="⚙ Properties">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel Orientation="Vertical">
                            <!-- Robot Info -->
                            <TextBlock Text="Robot Configuration" Foreground="#8888A0" FontSize="11"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ActiveRobotId}" Foreground="#C8C8E0"
                                       FontSize="10" FontFamily="Consolas" Margin="0,0,0,12"/>

                            <!-- Joint Angles Display -->
                            <TextBlock Text="Joint Angles (radians)" Foreground="#8888A0" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <TextBlock Text="J1:" Foreground="#A0A0B8" FontSize="10"/>
                                <TextBlock Text="{Binding J1, StringFormat='{}{0:F3}'}" Foreground="#E8E8F0"
                                           FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="J2:" Foreground="#A0A0B8" FontSize="10"/>
                                <TextBlock Text="{Binding J2, StringFormat='{}{0:F3}'}" Foreground="#E8E8F0"
                                           FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="J3:" Foreground="#A0A0B8" FontSize="10"/>
                                <TextBlock Text="{Binding J3, StringFormat='{}{0:F3}'}" Foreground="#E8E8F0"
                                           FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="J4:" Foreground="#A0A0B8" FontSize="10"/>
                                <TextBlock Text="{Binding J4, StringFormat='{}{0:F3}'}" Foreground="#E8E8F0"
                                           FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="J5:" Foreground="#A0A0B8" FontSize="10"/>
                                <TextBlock Text="{Binding J5, StringFormat='{}{0:F3}'}" Foreground="#E8E8F0"
                                           FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="J6:" Foreground="#A0A0B8" FontSize="10"/>
                                <TextBlock Text="{Binding J6, StringFormat='{}{0:F3}'}" Foreground="#E8E8F0"
                                           FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                            </UniformGrid>

                            <!-- Tracking Error -->
                            <TextBlock Text="Tracking Error" Foreground="#8888A0" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border Background="#2D2D3F" Padding="6" CornerRadius="4" Margin="0,0,0,12">
                                <TextBlock Foreground="#A0A0B8" FontSize="10" FontFamily="Consolas">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="TCP: {0:F2}mm | Max: {1} @ {2:F2}°">
                                            <Binding Path="LastTrackingError.TcpErrorMm"/>
                                            <Binding Path="LastTrackingError.MaxErrorJoint"/>
                                            <Binding Path="LastTrackingError.MaxErrorDeg"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Jog Controls -->
                <TabItem Header="🎮 Jog">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel Orientation="Vertical">
                            <!-- Jog Mode -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Mode:" Foreground="#8888A0" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <RadioButton Content="Joint" IsChecked="True" GroupName="JogMode"
                                             Foreground="#A0A0B8" FontSize="10" Margin="0,0,12,0"/>
                                <RadioButton Content="Cartesian" GroupName="JogMode"
                                             Foreground="#A0A0B8" FontSize="10"/>
                            </StackPanel>

                            <!-- Step Size -->
                            <TextBlock Text="Step Size:" Foreground="#8888A0" FontSize="10"
                                       Margin="0,0,0,4"/>
                            <Slider Minimum="0.001" Maximum="0.5" Value="0.01" TickFrequency="0.01"
                                    IsSnapToTickEnabled="True" Background="#3A3A4A"
                                    Foreground="#4A90D9" Margin="0,0,0,12"/>

                            <!-- Joint Jog Sliders J1-J6 -->
                            <TextBlock Text="Joint Jog (degrees)" Foreground="#8888A0" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <!-- J1 -->
                            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                                <TextBlock Text="J1 (Base)" Foreground="#A0A0B8" FontSize="9" Margin="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="-170" Maximum="170" Value="0" TickFrequency="1"
                                            Background="#3A3A4A" Foreground="#4A90D9" Height="20"/>
                                    <TextBlock Grid.Column="1" Text="0.0°" Foreground="#E8E8F0"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- J2 -->
                            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                                <TextBlock Text="J2 (Shoulder)" Foreground="#A0A0B8" FontSize="9" Margin="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="-65" Maximum="85" Value="0" TickFrequency="1"
                                            Background="#3A3A4A" Foreground="#4A90D9" Height="20"/>
                                    <TextBlock Grid.Column="1" Text="0.0°" Foreground="#E8E8F0"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- J3 -->
                            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                                <TextBlock Text="J3 (Elbow)" Foreground="#A0A0B8" FontSize="9" Margin="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="-180" Maximum="70" Value="0" TickFrequency="1"
                                            Background="#3A3A4A" Foreground="#4A90D9" Height="20"/>
                                    <TextBlock Grid.Column="1" Text="0.0°" Foreground="#E8E8F0"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- J4 -->
                            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                                <TextBlock Text="J4 (Wrist1)" Foreground="#A0A0B8" FontSize="9" Margin="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="-300" Maximum="300" Value="0" TickFrequency="1"
                                            Background="#3A3A4A" Foreground="#4A90D9" Height="20"/>
                                    <TextBlock Grid.Column="1" Text="0.0°" Foreground="#E8E8F0"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- J5 -->
                            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                                <TextBlock Text="J5 (Wrist2)" Foreground="#A0A0B8" FontSize="9" Margin="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="-130" Maximum="130" Value="0" TickFrequency="1"
                                            Background="#3A3A4A" Foreground="#4A90D9" Height="20"/>
                                    <TextBlock Grid.Column="1" Text="0.0°" Foreground="#E8E8F0"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- J6 -->
                            <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                                <TextBlock Text="J6 (Flange)" Foreground="#A0A0B8" FontSize="9" Margin="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="-360" Maximum="360" Value="0" TickFrequency="1"
                                            Background="#3A3A4A" Foreground="#4A90D9" Height="20"/>
                                    <TextBlock Grid.Column="1" Text="0.0°" Foreground="#E8E8F0"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- Home Button -->
                            <Button Content="🏠 Home Robot" Background="#4A90D9" Foreground="White"
                                    BorderThickness="0" Height="32" FontSize="11" FontWeight="SemiBold"
                                    Margin="0,0,0,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: Diagnostics -->
                <TabItem Header="🔍 Diagnostics">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Health Checks" Foreground="#8888A0" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Button Content="Run Health Check" Command="{Binding RunHealthCheckCommand}"
                                    Background="#4A90D9" Foreground="White" BorderThickness="0"
                                    Height="28" FontSize="10" Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding HealthResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}" Width="120"
                                                       Foreground="#A0A0B8" FontSize="10"/>
                                            <TextBlock Text="{Binding Ok, StringFormat='{}{0}'}" Width="40">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Ok}" Value="True">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Detail}" Foreground="#C8C8E0"
                                                       FontSize="10" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
