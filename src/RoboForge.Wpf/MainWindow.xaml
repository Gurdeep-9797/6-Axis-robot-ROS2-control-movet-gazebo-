<Window x:Class="RoboForge.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:conv="clr-namespace:RoboForge.Wpf.Converters"
        Title="RoboForge v8.0 — Offline" Height="900" Width="1440"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}" FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:OkToBrushConverter x:Key="OkToBrushConverter"/>
    </Window.Resources>

    <!-- Main Container -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/> <!-- Top Menu Bar -->
            <RowDefinition Height="70"/> <!-- Tool Bar & Mode Bar -->
            <RowDefinition Height="*"/>  <!-- Main Working Area -->
            <RowDefinition Height="180"/> <!-- Bottom Console -->
        </Grid.RowDefinitions>
        
        <!-- ROW 0: Menu Bar -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderMain}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="15,0">
                <TextBlock Text="RoboForge" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentCyan}" VerticalAlignment="Center"/>
                <TextBlock Text=" v8.0" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,4,15,0"/>
                <TextBlock Text="OFFLINE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource WarningAmber}" VerticalAlignment="Center" Margin="0,4,25,0"/>
                <Menu Background="Transparent" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center">
                    <MenuItem Header="File" />
                    <MenuItem Header="Edit" />
                    <MenuItem Header="Simulation" />
                    <MenuItem Header="Deploy" />
                    <MenuItem Header="View" />
                </Menu>
            </StackPanel>
        </Border>

        <!-- ROW 1: Tool Bar & Mode Bar -->
        <Border Grid.Row="1" Background="{StaticResource BgPrimary}" BorderBrush="{StaticResource BorderMain}" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Tools -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" /> <!-- Modes -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" /> <!-- Settings & Run -->
                </Grid.ColumnDefinitions>
                
                <!-- Tools -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" Tag="📄" Content="New" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="📂" Content="Open" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="💾" Content="Save" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="📤" Content="Export" Margin="0,0,10,0"/>
                    <Separator Style="{StaticResource VerticalSep}"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="↩" Content="Undo" Command="{Binding UndoCommand}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="↪" Content="Redo" Command="{Binding RedoCommand}" Margin="0,0,10,0"/>
                    <Separator Style="{StaticResource VerticalSep}"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="⚙" Content="Compile" Command="{Binding CompileCommand}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="▶" Content="Run" Command="{Binding RunCommand}" Foreground="{StaticResource SuccessGreen}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="⏸" Content="Pause" Command="{Binding PauseCommand}" Foreground="{StaticResource WarningAmber}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="⏹" Content="Stop" Command="{Binding StopCommand}" Foreground="{StaticResource ErrorRed}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="⏭" Content="Step" Command="{Binding StepCommand}" Margin="0,0,10,0"/>
                </StackPanel>

                <!-- Modes -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="MODE" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <Border Background="{StaticResource BgPanel}" CornerRadius="12" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Edit" Style="{StaticResource PillToggleButton}" IsChecked="{Binding ActiveMode, Converter={StaticResource EnumToBool}, ConverterParameter=Edit}"/>
                                <RadioButton Content="Simulate" Style="{StaticResource PillToggleButton}" IsChecked="{Binding ActiveMode, Converter={StaticResource EnumToBool}, ConverterParameter=Simulate}"/>
                                <RadioButton Content="Live" Style="{StaticResource PillToggleButton}" IsChecked="{Binding ActiveMode, Converter={StaticResource EnumToBool}, ConverterParameter=Live}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Right Tools -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" Tag="🐞" Content="Debug" Margin="0,0,15,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="📡" Content="I/O" Margin="0,0,15,0"/>
                    <Button Style="{StaticResource ToolbarButton}" Tag="⚙️" Content="Settings" Margin="0,0,30,0"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessGreen}" Margin="0,0,6,0"/>
                        <TextBlock Text="ROS 2" Foreground="{StaticResource SuccessGreen}" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 2: Main Workspace -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />  <!-- Left Sidebar Icons -->
                <ColumnDefinition Width="280" /> <!-- Left Active Panel -->
                <ColumnDefinition Width="*" />   <!-- Center Workspace -->
                <ColumnDefinition Width="320" /> <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar Icons -->
            <Border Grid.Column="0" Background="{StaticResource BgPrimary}" BorderBrush="{StaticResource BorderMain}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,15,0,0">
                    <RadioButton Style="{StaticResource SidebarTab}" Tag="&lt;/&gt;" Content="Program" IsChecked="True"/>
                    <RadioButton Style="{StaticResource SidebarTab}" Tag="🧩" Content="Blocks" />
                    <RadioButton Style="{StaticResource SidebarTab}" Tag="✢" Content="Motion" />
                    <RadioButton Style="{StaticResource SidebarTab}" Tag="🐞" Content="Debug" />
                    <RadioButton Style="{StaticResource SidebarTab}" Tag="🔧" Content="Config" />
                    <RadioButton Style="{StaticResource SidebarTab}" Tag="⚙" Content="Settings" />
                </StackPanel>
            </Border>

            <!-- Left Active Panel -->
            <Border Grid.Column="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderMain}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="SETTINGS" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" Margin="20,20,0,0"/>
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="ROS 2 BRIDGE" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="20,20,20,10"/>
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Status" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Foreground="{StaticResource SuccessGreen}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center Workspace (3D + Health Overlay) -->
            <Grid Grid.Column="2">
                <hx:Viewport3DX x:Name="Viewport" MSAA="Four" UseDefaultGestures="True" Background="{StaticResource BgPrimary}"/>
                
                <!-- v8.0 Health Check Overlay -->
                <Border Background="#CC000000" Visibility="{Binding IsHealthCheckRunning, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="PRE-FLIGHT HEALTH CHECK" Foreground="{StaticResource AccentCyan}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <ItemsControl ItemsSource="{Binding HealthResults}" Margin="0,0,0,30">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="300"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Ellipse Width="10" Height="10" Fill="{Binding Ok, Converter={StaticResource OkToBrushConverter}}" Margin="0,0,15,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="#FFAAAAAA" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="ABORT" Command="{Binding StopCommand}" Style="{StaticResource ToolbarButton}" Width="150"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right Panel (Diagnostics & Jog) -->
            <Border Grid.Column="3" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1,0,0,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="TRACKING ERROR (LIVE)" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Margin="0,0,0,20" Background="{StaticResource BgPrimary}" CornerRadius="8" Padding="12" Visibility="{Binding LastTrackingError, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="TCP DEVIATION" Foreground="{StaticResource TextSecondary}" FontSize="10"/>
                                <TextBlock Text="{Binding LastTrackingError.TcpErrorMm, StringFormat={}{0:F2} mm}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="{Binding LastTrackingError.MaxErrorDeg}" Maximum="5" Height="4" Foreground="{StaticResource ErrorRed}" Background="{StaticResource BgPanel}" BorderThickness="0"/>
                            <Grid Margin="0,4,0,0">
                                <TextBlock Text="{Binding LastTrackingError.MaxErrorJoint}" Foreground="{StaticResource TextSecondary}" FontSize="9"/>
                                <TextBlock Text="{Binding LastTrackingError.MaxErrorDeg, StringFormat={}{0:F2}°}" Foreground="{StaticResource TextSecondary}" FontSize="9" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="JOINT CONTROL" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    <!-- Joint controls go here -->
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 3: Console -->
        <Border Grid.Row="3" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderMain}" BorderThickness="0,1,0,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ConsoleEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="{Binding Time}" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" FontSize="11" Width="65"/>
                                <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
