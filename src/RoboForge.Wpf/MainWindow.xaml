<Window x:Class="RoboForge.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf"
        xmlns:local="clr-namespace:RoboForge.Wpf"
        Title="RoboForge IDE"
        Width="1600" Height="1000"
        Background="#0E0E10"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>   <!-- Custom Title Bar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="28"/>   <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ═══ CUSTOM TITLE BAR ═══ -->
        <Border Grid.Row="0" Background="#18181B" BorderBrush="#27272A" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙ RoboForge IDE" Foreground="#A1A1AA" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="— Untitled.rfproj" Foreground="#52525B" FontSize="12" Margin="8,0,0,0"/>
                    <TextBlock Text="●" Foreground="#22C55E" FontSize="10" Margin="16,0,0,0" ToolTip="Connected"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="─" Width="36" Height="28" Background="Transparent" Foreground="#A1A1AA" BorderThickness="0" Click="Minimize_Click"/>
                    <Button Content="□" Width="36" Height="28" Background="Transparent" Foreground="#A1A1AA" BorderThickness="0" Click="Maximize_Click"/>
                    <Button Content="✕" Width="36" Height="28" Background="Transparent" Foreground="#A1A1AA" BorderThickness="0" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN 3-COLUMN LAYOUT ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="280"/>  <!-- Column 1: Scene Tree + 3D Viewport -->
                <ColumnDefinition Width="6"/>                   <!-- Column 2: Draggable Splitter -->
                <ColumnDefinition Width="*"/>                   <!-- Column 3: Program Editor -->
            </Grid.ColumnDefinitions>

            <!-- ═══ COLUMN 1: LEFT PANEL — Scene Tree + 3D Viewport ═══ -->
            <Grid Grid.Column="0" Background="#121214">
                <Grid.RowDefinitions>
                    <RowDefinition Height="45*"/>  <!-- 45%: Scene Tree -->
                    <RowDefinition Height="55*"/>  <!-- 55%: 3D Viewport -->
                </Grid.RowDefinitions>

                <!-- SCENE TREE -->
                <Border Grid.Row="0" BorderBrush="#27272A" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- Tree Header -->
                        <Border DockPanel.Dock="Top" Background="#1A1A1E" Padding="12,8" BorderBrush="#27272A" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="SCENE HIERARCHY" Foreground="#71717A" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="＋" Width="20" Height="20" Background="Transparent" Foreground="#52525B" BorderThickness="0" FontSize="14" ToolTip="Add Node"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Tree View -->
                        <TreeView x:Name="SceneTree" Background="#121214" BorderThickness="0" Foreground="#D4D4D8" FontSize="11"
                                  SelectedItemChanged="SceneTree_SelectedItemChanged"
                                  VirtualizingStackPanel.IsVirtualizing="True">
                            <TreeView.Resources>
                                <!-- Robot Root Node Template -->
                                <HierarchicalDataTemplate DataType="{x:Type local:RobotTreeNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="🤖" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <Ellipse Width="6" Height="6" Fill="#22C55E" Margin="8,0,0,0" ToolTip="Healthy"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                                <!-- Link Node Template -->
                                <HierarchicalDataTemplate DataType="{x:Type local:LinkTreeNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <TextBlock Text="🔩" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#A1A1AA"/>
                                        <Ellipse Width="6" Height="6" Fill="#22C55E" Margin="8,0,0,0"/>
                                        <Button Content="👁" Width="16" Height="16" Background="Transparent" Foreground="#52525B" BorderThickness="0" Margin="4,0,0,0" FontSize="9"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                                <!-- Joint Node Template -->
                                <DataTemplate DataType="{x:Type local:JointTreeNode}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <TextBlock Text="⚙" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#71717A"/>
                                        <TextBlock Text=" — " Foreground="#3F3F46"/>
                                        <TextBlock Text="{Binding JointType}" Foreground="#52525B" FontSize="10"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- 3D VIEWPORT -->
                <Border Grid.Row="1" Background="#0E0E10" BorderBrush="#27272A" BorderThickness="0,1,0,0">
                    <Grid>
                        <hx:HelixViewport3D x:Name="RobotViewport" ShowViewCube="True" ShowCoordinateSystem="True" ZoomExtentsWhenLoaded="True"
                                            Background="#0E0E10">
                            <hx:HelixViewport3D.Camera>
                                <PerspectiveCamera Position="3,2.5,3" LookDirection="-3,-2.5,-3" UpDirection="0,1,0" FieldOfView="45"/>
                            </hx:HelixViewport3D.Camera>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Direction="-1,-1,-1" Color="#FFFFFF"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Direction="1,0.5,0.5" Color="#6090C0"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <AmbientLight Color="#303030"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                        </hx:HelixViewport3D>

                        <!-- Startup & Homing Button (bottom-left of viewport) -->
                        <Button HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
                                Background="#007ACC" Foreground="White" BorderThickness="0"
                                Padding="12,8" FontSize="12" FontWeight="SemiBold"
                                Click="HomingButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠"/>
                                <TextBlock Text="Startup &amp; Homing" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ COLUMN 2: DRAGGABLE SPLITTER ═══ -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#18181B"
                          ShowsPreview="False" Cursor="SizeWE">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Background" Value="#18181B"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27272A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- ═══ COLUMN 3: RIGHT PANEL — Program Editor ═══ -->
            <Grid Grid.Column="2" Background="#121214">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>   <!-- Tab Bar -->
                    <RowDefinition Height="*"/>    <!-- Editor Area -->
                    <RowDefinition Height="Auto" MinHeight="100" MaxHeight="300"/> <!-- Diagnostics Panel -->
                </Grid.RowDefinitions>

                <!-- TAB BAR -->
                <Border Grid.Row="0" Background="#1A1A1E" BorderBrush="#27272A" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Button x:Name="TabBlocks" Content="🧱 Blocks" Background="#27272A" Foreground="#E4E4E7" BorderThickness="0"
                                Padding="16,8" FontSize="12" Click="TabBlocks_Click"/>
                        <Button x:Name="TabScript" Content="📝 Script" Background="Transparent" Foreground="#71717A" BorderThickness="0"
                                Padding="16,8" FontSize="12" Margin="4,0,0,0" Click="TabScript_Click"/>
                        <Button Content="📡 IO" Background="Transparent" Foreground="#71717A" BorderThickness="0"
                                Padding="16,8" FontSize="12" Margin="4,0,0,0"/>
                        <Button Content="⚙ Config" Background="Transparent" Foreground="#71717A" BorderThickness="0"
                                Padding="16,8" FontSize="12" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- BLOCK EDITOR (shown when Blocks tab active) -->
                <Border Grid.Row="1" x:Name="BlockEditorPanel" Background="#121214" BorderBrush="#27272A" BorderThickness="0,0,0,1">
                    <Grid>
                        <!-- Block Library (left side of editor) -->
                        <Border Width="180" HorizontalAlignment="Left" Background="#1A1A1E" BorderBrush="#27272A" BorderThickness="0,0,1,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Padding="12,8" BorderBrush="#27272A" BorderThickness="0,0,0,1">
                                    <TextBlock Text="BLOCK LIBRARY" Foreground="#71717A" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="8">
                                        <!-- Motion Blocks -->
                                        <TextBlock Text="MOTION" Foreground="#52525B" FontSize="9" FontWeight="SemiBold" Margin="0,4,0,2"/>
                                        <Button Content="MoveJ" Background="#4A90D9" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="MoveL" Background="#4A90D9" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="MoveC" Background="#4A90D9" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="MoveAbsJ" Background="#4A90D9" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <!-- IO Blocks -->
                                        <TextBlock Text="I/O" Foreground="#52525B" FontSize="9" FontWeight="SemiBold" Margin="0,12,0,2"/>
                                        <Button Content="SetDO" Background="#E8A020" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="PulseDO" Background="#E8A020" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="WaitDI" Background="#E8A020" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <!-- Flow Control -->
                                        <TextBlock Text="FLOW" Foreground="#52525B" FontSize="9" FontWeight="SemiBold" Margin="0,12,0,2"/>
                                        <Button Content="Wait" Background="#8B5CF6" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="If/Else" Background="#8B5CF6" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="While" Background="#8B5CF6" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="For" Background="#8B5CF6" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <!-- Robot Specific -->
                                        <TextBlock Text="ROBOT" Foreground="#52525B" FontSize="9" FontWeight="SemiBold" Margin="0,12,0,2"/>
                                        <Button Content="GripperOpen" Background="#22C55E" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="GripperClose" Background="#22C55E" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="ToolChange" Background="#22C55E" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <!-- Structure -->
                                        <TextBlock Text="STRUCTURE" Foreground="#52525B" FontSize="9" FontWeight="SemiBold" Margin="0,12,0,2"/>
                                        <Button Content="Routine" Background="#F43F5E" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                        <Button Content="CallRoutine" Background="#F43F5E" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,1" FontSize="10" HorizontalContentAlignment="Left"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Block Canvas (main editor area) -->
                        <ScrollViewer x:Name="BlockScrollViewer" Margin="180,0,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <StackPanel x:Name="BlockCanvas" Margin="16"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- SCRIPT EDITOR (hidden by default) -->
                <Border Grid.Row="1" x:Name="ScriptEditorPanel" Background="#121214" Visibility="Collapsed">
                    <TextBox Background="#0E0E10" Foreground="#D4D4D8" BorderThickness="0" Padding="16"
                             FontFamily="JetBrains Mono, Consolas" FontSize="13"
                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                             Text="MODULE main&#10;  PROC&#10;    ! Program code here&#10;  ENDPROC&#10;ENDMODULE"/>
                </Border>

                <!-- DIAGNOSTICS PANEL (collapsible) -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Diagnostics Header -->
                    <Border Grid.Row="0" Background="#1A1A1E" BorderBrush="#27272A" BorderThickness="0,1,0,0" Padding="12,6">
                        <Grid>
                            <TextBlock Text="DIAGNOSTICS" Foreground="#71717A" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="▶ Run" Background="#22C55E" Foreground="White" BorderThickness="0" Padding="12,4" FontSize="10" FontWeight="SemiBold" Margin="0,0,4,0" Click="RunProgram_Click"/>
                                <Button Content="⏸ Pause" Background="#E8A020" Foreground="White" BorderThickness="0" Padding="12,4" FontSize="10" Margin="0,0,4,0"/>
                                <Button Content="⏹ Stop" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="12,4" FontSize="10" Margin="0,0,8,0" Click="StopProgram_Click"/>
                                <Button Content="▲" Width="20" Height="20" Background="Transparent" Foreground="#52525B" BorderThickness="0" FontSize="10" Click="CollapseDiagnostics_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Diagnostics Messages -->
                    <ListBox Grid.Row="1" x:Name="DiagnosticsList" Background="#0E0E10" BorderThickness="0" Foreground="#A1A1AA" FontSize="11"
                             VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <TextBlock Text="{Binding Time}" Foreground="#52525B" Width="60"/>
                                    <TextBlock Text="{Binding Level}" Foreground="{Binding LevelColor}" Width="50" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Background="#007ACC">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Connection + Device -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,6,0"/>
                    <TextBlock Text="Connected" Foreground="White" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock Text="Device: None" Foreground="White" FontSize="11" Opacity="0.8"/>
                </StackPanel>

                <!-- Center: Mode + Speed -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="MODE:" Foreground="White" FontSize="10" Opacity="0.7" Margin="0,0,6,0"/>
                    <Button Content="SIM" Background="#E8A020" Foreground="White" BorderThickness="0" Padding="8,2" FontSize="10" FontWeight="SemiBold"/>
                    <Slider Width="80" Value="50" Minimum="0" Maximum="100" Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Speed: 50%" Foreground="White" FontSize="10"/>
                </StackPanel>

                <!-- Right: Save timestamp -->
                <TextBlock Grid.Column="2" Text="Saved: --:--:--" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
