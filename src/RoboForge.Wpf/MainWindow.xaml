<Window x:Class="RoboForge.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf"
        xmlns:local="clr-namespace:RoboForge.Wpf"
        Title="RoboForge v8.2"
        Width="1600" Height="1000"
        Background="#0D1117"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Button Styles -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconRailButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#30363D" BorderThickness="2,0,0,0" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6,6,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="True">
                                <Setter Property="Background" Value="#161B22"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="True">
                                <Setter Property="Background" Value="#1F6FEB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>   <!-- Top Menu Bar -->
            <RowDefinition Height="44"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="Auto"/> <!-- Diagnostics Panel -->
            <RowDefinition Height="28"/>   <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TOP MENU BAR ═══ -->
        <Border Grid.Row="0" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Logo + Menus -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RoboForge" Foreground="#C9D1D9" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="v8.2" Foreground="#484F58" FontSize="10" VerticalAlignment="Center" Margin="4,0,16,0"/>
                    
                    <Menu Background="Transparent" Foreground="#C9D1D9" VerticalAlignment="Center">
                        <MenuItem Header="File" Padding="8,4"/>
                        <MenuItem Header="Edit" Padding="8,4"/>
                        <MenuItem Header="Simulation" Padding="8,4"/>
                        <MenuItem Header="Deploy" Padding="8,4"/>
                        <MenuItem Header="View" Padding="8,4"/>
                    </Menu>
                </StackPanel>

                <!-- Right: Project name + status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PickPlace_Cell_01" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#484F58" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StatusText" Text="STOPPED" Foreground="#8B949E" FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Ellipse Width="8" Height="8" Fill="#238636" Margin="0,0,4,0"/>
                    <TextBlock Text="BRIDGE" Foreground="#238636" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- File ops -->
                    <ColumnDefinition Width="Auto"/>  <!-- Navigation -->
                    <ColumnDefinition Width="Auto"/>  <!-- Execution -->
                    <ColumnDefinition Width="Auto"/>  <!-- Mode -->
                    <ColumnDefinition Width="*"/>     <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- Right tools -->
                </Grid.ColumnDefinitions>

                <!-- File Operations -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="New Project" Content="📄" Click="NewProject_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Open Project" Content="📂" Click="OpenProject_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Save" Content="💾" Click="SaveProject_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Export" Content="⬇" Click="ExportProject_Click"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Go Home" Content="🏠" Click="GoHome_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Undo" Content="↩" Click="Undo_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Redo" Content="↪" Click="Redo_Click"/>
                </StackPanel>

                <!-- Execution Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Compile" Content="⚡" Click="Compile_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Run Program" Content="▶" Foreground="#238636" Click="Run_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Pause" Content="⏸" Click="Pause_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Stop" Content="⏹" Foreground="#F85149" Click="Stop_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Step" Content="⏭" Click="Step_Click"/>
                </StackPanel>

                <!-- Operation Mode -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="MODE" Foreground="#484F58" FontSize="9" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Style="{StaticResource ModeButton}" Tag="True" Content="Edit" Click="EditMode_Click"/>
                    <Button Style="{StaticResource ModeButton}" Content="Simulate" Click="SimulateMode_Click"/>
                    <Button Style="{StaticResource ModeButton}" Content="Live" Click="LiveMode_Click"/>
                </StackPanel>

                <!-- Spacer -->
                <Grid Grid.Column="4"/>

                <!-- Right Tools -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="IK SOLVER" Foreground="#484F58" FontSize="9" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="IkSolverDropdown" Width="100" Height="24" Background="#21262D" Foreground="#D29922" BorderBrush="#30363D" BorderThickness="1" SelectedIndex="0" SelectionChanged="IkSolverDropdown_SelectionChanged" Margin="0,0,12,0">
                        <ComboBoxItem Content="⚠ OFFLINE" Foreground="#D29922" IsSelected="True"/>
                        <ComboBoxItem Content="● MoveIt (Online)" Foreground="#238636"/>
                        <ComboBoxItem Content="● Analytical" Foreground="#58A6FF"/>
                    </ComboBox>

                    <TextBlock Text="MOTOR PWM" Foreground="#484F58" FontSize="9" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="MotorPwmSlider" Width="60" Value="50" Minimum="0" Maximum="100" VerticalAlignment="Center" Margin="0,0,4,0" ValueChanged="MotorPwm_ValueChanged"/>
                    <TextBlock x:Name="MotorPwmText" Text="50%" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <Border Background="#238636" Padding="8,4" CornerRadius="4" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="BridgeToggle_Click">
                        <TextBlock Text="● Live" Foreground="White" FontSize="11"/>
                    </Border>

                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Debug" Content="🐛" Click="DebugTab_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="I/O" Content="(io)" Click="IoTab_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" ToolTip="Settings" Content="⚙" Click="SidebarButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>   <!-- Icon Rail -->
                <ColumnDefinition Width="260"/>  <!-- Left Panel -->
                <ColumnDefinition Width="*"/>    <!-- Center: Editor + Viewport -->
                <ColumnDefinition Width="300"/>  <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- ICON RAIL -->
            <Border Grid.Column="0" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <Button Style="{StaticResource SidebarIcon}" Tag="True" ToolTip="Program" Content="📋" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Blocks" Content="🧱" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Scene" Content="🎬" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="3D View" Content="🎥" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Motion" Content="🏃" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="I/O" Content="📡" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Debug" Content="🐛" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Config" Content="⚙" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="ROS 2" Content="🔗" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Settings" Content="🔧" Click="SidebarButton_Click"/>
                    <Button Style="{StaticResource SidebarIcon}" ToolTip="Project" Content="📁" Click="SidebarButton_Click"/>
                </StackPanel>
            </Border>

            <!-- LEFT PANEL: PROGRAM TREE -->
            <Border Grid.Column="1" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#161B22" Padding="12,8" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <TextBlock Text="PROGRAM TREE" Foreground="#8B949E" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Tree -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                        <TreeView x:Name="SceneTree" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="11">
                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                </Style>
                            </TreeView.Resources>

                            <!-- Main Program -->
                            <TreeViewItem Header="📁 Main Program" IsExpanded="True">
                                <TreeViewItem Header="🟢 Initialize" IsExpanded="True" Padding="20,2,4,2">
                                    <TreeViewItem Header="J MoveJ Home" Padding="36,2,4,2" Foreground="#79C0FF">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#1F6FEB" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                        <TextBlock Text="J" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                    <TreeViewItem Header="🔧 SetDO Gripper OFF" Padding="36,2,4,2">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#D29922" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                        <TextBlock Text="⚡" Foreground="White" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                    <TreeViewItem Header="📊 Set counter = 0" Padding="36,2,4,2" Foreground="#8B949E"/>
                                </TreeViewItem>

                                <TreeViewItem Header="🔴 While TRUE" IsExpanded="True" Padding="20,2,4,2">
                                    <TreeViewItem Header="🟢 PickAndPlace" IsExpanded="True" Padding="36,2,4,2">
                                        <TreeViewItem Header="J MoveJ Approach" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#1F6FEB" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="J" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="L MoveL Pick" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#238636" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="L" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="🤏 Gripper Close" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#A371F7" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="G" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="⏱ Wait 0.2s" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#A371F7" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="W" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="L MoveL Lift" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#238636" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="L" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="J MoveJ Place" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#1F6FEB" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="J" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="🤏 Gripper Open" Padding="52,2,4,2">
                                            <TreeViewItem.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#A371F7" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                            <TextBlock Text="G" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeViewItem.HeaderTemplate>
                                        </TreeViewItem>
                                        <TreeViewItem Header="🔢 Increment counter" Padding="52,2,4,2" Foreground="#8B949E"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="⏱ Wait 0.5s" Padding="36,2,4,2">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#A371F7" Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                        <TextBlock Text="W" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding}" Foreground="#C9D1D9"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                </TreeViewItem>
                            </TreeViewItem>
                        </TreeView>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- CENTER: EDITOR + VIEWPORT -->
            <Border Grid.Column="2" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>  <!-- Tab bar -->
                        <RowDefinition Height="*"/>   <!-- Content -->
                    </Grid.RowDefinitions>

                    <!-- Tab Bar -->
                    <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left tabs -->
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource TabButton}" Tag="True" Content="📝 Code Editor"/>
                                <Button Style="{StaticResource TabButton}" Content="🎥 3D Viewport"/>
                            </StackPanel>

                            <!-- Right tabs -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Style="{StaticResource TabButton}" Content="Inspect" Margin="0,0,4,0" Click="InspectTab_Click"/>
                                <Button Style="{StaticResource TabButton}" Tag="True" Content="Properties" Click="PropertiesTab_Click"/>
                                <Button Style="{StaticResource TabButton}" Content="I/O" Margin="0,0,4,0" Click="IoTab_Click"/>
                                <Button Style="{StaticResource TabButton}" Content="Debug" Click="DebugTab_Click"/>
                                <Button Style="{StaticResource TabButton}" Content="ROS 2" Click="Ros2Tab_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>   <!-- Script/Blocks -->
                            <ColumnDefinition Width="*"/>   <!-- 3D Viewport -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Script/Blocks Editor -->
                        <Border Grid.Column="0" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,1,0">
                            <DockPanel>
                                <!-- Editor Header -->
                                <Border DockPanel.Dock="Top" Background="#161B22" Padding="12,8" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="PickPlace_Main.mod" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>

                                        <!-- Script/Blocks Toggle -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Style="{StaticResource ModeButton}" Content="Script" Margin="0,0,4,0" Click="ScriptTab_Click"/>
                                            <Button Style="{StaticResource ModeButton}" Tag="True" Content="Blocks" Click="BlocksTab_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Block Editor -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                    <StackPanel>
                                        <!-- Main Program -->
                                        <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="#238636" Width="20" Height="20" CornerRadius="10" Margin="0,0,8,0">
                                                        <TextBlock Text="fn" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Main Program" Foreground="#C9D1D9" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="3 instr" Foreground="#484F58" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </StackPanel>

                                                <!-- MoveJ Home -->
                                                <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#1F6FEB" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                            <TextBlock Text="J" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="MoveJ Home" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="(0,0,1500) v500" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- SetDO Gripper OFF -->
                                                <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#D29922" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                            <TextBlock Text="⚡" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="SetDO Gripper OFF" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="DO_Gripper=0" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Set counter -->
                                                <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#484F58" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                            <TextBlock Text="=" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="Set counter = 0" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="counter=0" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- While TRUE Loop -->
                                        <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="#F85149" Width="20" Height="20" CornerRadius="10" Margin="0,0,8,0">
                                                        <TextBlock Text="∞" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="While TRUE" Foreground="#C9D1D9" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="= loop" Foreground="#484F58" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </StackPanel>

                                                <!-- PickAndPlace Function -->
                                                <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,4">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <Border Background="#238636" Width="20" Height="20" CornerRadius="10" Margin="0,0,8,0">
                                                                <TextBlock Text="fn" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="PickAndPlace" Foreground="#C9D1D9" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <TextBlock Text="8 instr" Foreground="#484F58" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                        </StackPanel>

                                                        <!-- MoveJ Approach -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#1F6FEB" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="J" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="MoveJ Approach" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="(500,0,1200) v500" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- MoveL Pick -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#238636" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="L" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="MoveL Pick" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="(500,0,900) v200" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Gripper Close -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#A371F7" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="G" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="Gripper Close" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="w=40mm f=50N" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Wait 0.2s -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#A371F7" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="W" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="Wait 0.2s" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="0.20s" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- MoveL Lift -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#238636" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="L" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="MoveL Lift" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="(500,0,1200) v500" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- MoveJ Place -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#1F6FEB" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="J" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="MoveJ Place" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="(-400,300,1000) v500" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Gripper Open -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#A371F7" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="G" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="Gripper Open" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="w=80mm" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Increment Counter -->
                                                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Background="#484F58" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                                    <TextBlock Text="+1" Foreground="White" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="Increment counter" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="counter+=1" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Wait 0.5s -->
                                                <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Padding="8,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#A371F7" Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0">
                                                            <TextBlock Text="W" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="Wait 0.5s" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="0.50s" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- RIGHT: 3D Viewport -->
                        <Border Grid.Column="1" Background="#0D1117">
                            <Grid>
                                <!-- 3D Viewport -->
                                <hx:HelixViewport3D x:Name="RobotViewport" ShowViewCube="True" ShowCoordinateSystem="True" ZoomExtentsWhenLoaded="True"
                                                    Background="#0D1117">
                                    <hx:HelixViewport3D.Camera>
                                        <PerspectiveCamera Position="3,2.5,3" LookDirection="-3,-2.5,-3" UpDirection="0,1,0" FieldOfView="45"/>
                                    </hx:HelixViewport3D.Camera>
                                    <ModelVisual3D>
                                        <ModelVisual3D.Content>
                                            <DirectionalLight Direction="-1,-1,-1" Color="#FFFFFF"/>
                                        </ModelVisual3D.Content>
                                    </ModelVisual3D>
                                    <ModelVisual3D>
                                        <ModelVisual3D.Content>
                                            <DirectionalLight Direction="1,0.5,0.5" Color="#6090C0"/>
                                        </ModelVisual3D.Content>
                                    </ModelVisual3D>
                                    <ModelVisual3D>
                                        <ModelVisual3D.Content>
                                            <AmbientLight Color="#303030"/>
                                        </ModelVisual3D.Content>
                                    </ModelVisual3D>
                                </hx:HelixViewport3D>

                                <!-- Viewport Toolbar -->
                                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource ToolbarButton}" Content="↺" Width="28" Height="28" ToolTip="Reset View" Click="ResetView_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="👁" Width="28" Height="28" ToolTip="Show/Hide" Click="ToggleGrid_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="🚫" Width="28" Height="28" ToolTip="Collision View" Click="CollisionView_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="🖱" Width="28" Height="28" ToolTip="Select" Click="SelectTool_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="⊞" Width="28" Height="28" ToolTip="Grid" Click="ToggleGrid_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="↻" Width="28" Height="28" ToolTip="Rotate" Click="SidebarButton_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="⤢" Width="28" Height="28" ToolTip="Expand" Click="SidebarButton_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="📷" Width="28" Height="28" ToolTip="Screenshot" Click="SidebarButton_Click"/>
                                        <Button Style="{StaticResource ToolbarButton}" Content="☷" Width="28" Height="28" ToolTip="Layers" Click="SidebarButton_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Robot Selector -->
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8">
                                    <StackPanel>
                                        <Button Style="{StaticResource ToolbarButton}" Background="#1F6FEB" Foreground="White" Content="IRB 6700" Padding="8,4" Margin="0,0,0,4" Click="RobotSelector_Click" Tag="IRB 6700"/>
                                        <Button Style="{StaticResource ToolbarButton}" Background="#21262D" Foreground="#8B949E" Content="IRB 4600" Padding="8,4" Click="RobotSelector_Click" Tag="IRB 4600"/>
                                    </StackPanel>
                                </Border>

                                <!-- Axis Gizmo -->
                                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="16" Height="16" Fill="#F85149" Margin="0,0,4,0"/>
                                            <TextBlock Text="X" Foreground="#F85149" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="16" Height="16" Fill="#3FB950" Margin="0,0,4,0"/>
                                            <TextBlock Text="Y" Foreground="#3FB950" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="16" Height="16" Fill="#58A6FF" Margin="0,0,4,0"/>
                                            <TextBlock Text="Z" Foreground="#58A6FF" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="RMB = Orbit" Foreground="#484F58" FontSize="9" Margin="0,4,0,0"/>
                                        <TextBlock Text="Ctrl+RMB = Pan" Foreground="#484F58" FontSize="9"/>
                                        <TextBlock Text="Scroll = Zoom" Foreground="#484F58" FontSize="9"/>
                                        <TextBlock Text="G = Move" Foreground="#484F58" FontSize="9" Margin="0,4,0,0"/>
                                        <TextBlock Text="R = Rotate" Foreground="#484F58" FontSize="9"/>
                                        <TextBlock Text="S = Scale" Foreground="#484F58" FontSize="9"/>
                                        <TextBlock Text="Esc = Deselect" Foreground="#484F58" FontSize="9"/>
                                    </StackPanel>
                                </Border>

                                <!-- Speed Slider -->
                                <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Speed" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Slider x:Name="SpeedSlider" Width="80" Value="100" Minimum="0" Maximum="100" VerticalAlignment="Center" ValueChanged="SpeedSlider_ValueChanged"/>
                                        <TextBlock x:Name="SpeedText" Text="100%" Foreground="#C9D1D9" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: PROPERTIES -->
            <Border Grid.Column="3" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,0,0">
                <DockPanel>
                    <!-- Header Tabs -->
                    <Border DockPanel.Dock="Top" Background="#161B22" Padding="8,0" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource TabButton}" Tag="True" Content="PROPS" Padding="16,8" Click="PropsTab_Click"/>
                            <Button Style="{StaticResource TabButton}" Content="JOG" Padding="16,8" Margin="4,0,0,0" Click="JogTab_Click"/>
                            <Button Style="{StaticResource TabButton}" Content="OBJECT" Padding="16,8" Margin="4,0,0,0" Click="ObjectTab_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Properties Content -->
                    <Border Background="#0D1117">
                        <Grid>
                            <TextBlock Text="Select a block to edit" Foreground="#484F58" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══ DIAGNOSTICS PANEL ═══ -->
        <Grid Grid.Row="3" MinHeight="120" MaxHeight="300">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#161B22" Padding="12,6" BorderBrush="#30363D" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="DIAGNOSTICS &amp; DEBUG" Foreground="#8B949E" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource ToolbarButton}" Background="#1F6FEB" Foreground="White" Content="Run Check" Padding="12,4" Margin="0,0,4,0" Click="RunCheck_Click"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="🗑" Width="24" Height="24" Click="ClearDiagnostics_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Background="#0D1117">
                <Grid>
                    <ListBox x:Name="DiagnosticsList" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="11" VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="12,2">
                                    <TextBlock Text="{Binding Time}" Foreground="#484F58" Width="60"/>
                                    <TextBlock Text="{Binding Level}" Foreground="{Binding LevelColor}" Width="50" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom toolbar -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource ToolbarButton}" Content="▶ Step" Margin="0,0,12,0" Click="Step_Click"/>
                            <TextBlock Text="Breakpoints: 1" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="4" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Connection + Device -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#484F58" Margin="0,0,6,0"/>
                    <TextBlock Text="Disconnected" Foreground="#8B949E" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock Text="Device: None" Foreground="#8B949E" FontSize="11" Opacity="0.8"/>
                </StackPanel>

                <!-- Center: Mode + Speed -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="MODE:" Foreground="#484F58" FontSize="10" Opacity="0.7" Margin="0,0,6,0"/>
                    <Button Content="Edit" Background="#1F6FEB" Foreground="White" BorderThickness="0" Padding="8,2" FontSize="10" FontWeight="SemiBold" Margin="0,0,4,0"/>
                    <Slider Width="80" Value="50" Minimum="0" Maximum="100" Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Speed: 50%" Foreground="#C9D1D9" FontSize="10"/>
                </StackPanel>

                <!-- Right: Save timestamp -->
                <TextBlock Grid.Column="2" Text="Saved: --:--:--" Foreground="#484F58" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
