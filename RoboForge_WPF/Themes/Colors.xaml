<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══ BACKGROUNDS ═══ -->
    <SolidColorBrush x:Key="Bg.Deepest"     Color="#0A0E14"/>  <!-- Viewport / darkest -->
    <SolidColorBrush x:Key="Bg.Console"      Color="#0D1015"/>
    <SolidColorBrush x:Key="Bg.Code"         Color="#0F1318"/>
    <SolidColorBrush x:Key="Bg.Panel"        Color="#151920"/>
    <SolidColorBrush x:Key="Bg.Ribbon"       Color="#181C22"/>
    <SolidColorBrush x:Key="Bg.Header"       Color="#1C2028"/>
    <SolidColorBrush x:Key="Bg.Surface"      Color="#1F2430"/>
    <SolidColorBrush x:Key="Bg.Accent"       Color="#252B35"/>

    <!-- ═══ BORDERS ═══ -->
    <SolidColorBrush x:Key="Border.Default"  Color="#2A2F38"/>
    <SolidColorBrush x:Key="Border.Light"    Color="#353B46"/>
    <SolidColorBrush x:Key="Border.Input"    Color="#3A4050"/>
    <SolidColorBrush x:Key="Border.Glow"     Color="#2B8FED"/>

    <!-- ═══ TEXT ═══ -->
    <SolidColorBrush x:Key="Text.Primary"    Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Text.Secondary"  Color="#94A3B8"/>
    <SolidColorBrush x:Key="Text.Muted"      Color="#64748B"/>
    <SolidColorBrush x:Key="Text.Inverted"   Color="#0A0E14"/>

    <!-- ═══ PRIMARY ACCENT (Blue) ═══ -->
    <SolidColorBrush x:Key="Accent.Primary"       Color="#2B8FED"/>
    <SolidColorBrush x:Key="Accent.PrimaryLight"   Color="#5AADFF"/>
    <SolidColorBrush x:Key="Accent.PrimaryDark"    Color="#1A6FCC"/>
    <Color x:Key="Accent.Primary.Color">#2B8FED</Color>

    <!-- ═══ STATUS COLORS ═══ -->
    <SolidColorBrush x:Key="Status.Ok"       Color="#22C55E"/>
    <SolidColorBrush x:Key="Status.Warning"  Color="#F59E0B"/>
    <SolidColorBrush x:Key="Status.Error"    Color="#EF4444"/>
    <SolidColorBrush x:Key="Status.Info"     Color="#2B8FED"/>

    <!-- ═══ CODE EDITOR ═══ -->
    <SolidColorBrush x:Key="Code.Keyword"    Color="#5AADFF"/>
    <SolidColorBrush x:Key="Code.String"     Color="#22C55E"/>
    <SolidColorBrush x:Key="Code.Comment"    Color="#4A5568"/>
    <SolidColorBrush x:Key="Code.Number"     Color="#F59E0B"/>
    <SolidColorBrush x:Key="Code.Function"   Color="#A78BFA"/>
    <SolidColorBrush x:Key="Code.LineNum"    Color="#374151"/>

    <!-- ═══ BLOCK TYPE COLORS ═══ -->
    <SolidColorBrush x:Key="Block.Move"      Color="#2B7DE9"/>
    <SolidColorBrush x:Key="Block.Logic"     Color="#F59E0B"/>
    <SolidColorBrush x:Key="Block.IO"        Color="#22C55E"/>
    <SolidColorBrush x:Key="Block.Wait"      Color="#A78BFA"/>
    <SolidColorBrush x:Key="Block.Loop"      Color="#EC4899"/>

    <!-- ═══ LED ═══ -->
    <SolidColorBrush x:Key="Led.On"          Color="#22C55E"/>
    <SolidColorBrush x:Key="Led.Off"         Color="#2A3040"/>

    <!-- ═══ CONSOLE ═══ -->
    <SolidColorBrush x:Key="Console.Text"    Color="#50FA7B"/>
    <SolidColorBrush x:Key="Console.Error"   Color="#EF6868"/>
    <SolidColorBrush x:Key="Console.Warning" Color="#F5B040"/>

    <!-- ═══ FONTS ═══ -->
    <FontFamily x:Key="Font.UI">Segoe UI, Inter, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">JetBrains Mono, Cascadia Code, Consolas, monospace</FontFamily>
</ResourceDictionary>
