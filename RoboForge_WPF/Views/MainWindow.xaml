<Window x:Class="RoboForge_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        xmlns:local="clr-namespace:RoboForge_WPF.Views"
        Title="RoboForge — Industrial Robot Programming IDE"
        Width="1440" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource Bg.Deepest}"
        Foreground="{StaticResource Text.Primary}"
        FontFamily="{StaticResource Font.UI}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Top Ribbon -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Console -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 0: TOP RIBBON                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource Bg.Ribbon}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>  <!-- Menu Bar -->
                    <RowDefinition Height="80"/>  <!-- Ribbon Toolbar -->
                </Grid.RowDefinitions>

                <!-- ── Menu Bar ── -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="12,0">
                        <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Accent.Primary}"/>
                        <TextBlock Text="RoboForge" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource Accent.Primary}"/>
                    </StackPanel>

                    <!-- Menu Items -->
                    <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="{StaticResource Text.Secondary}" FontSize="12" Margin="16,0" VerticalAlignment="Center">
                        <MenuItem Header="File">
                            <MenuItem Header="New Program" InputGestureText="Ctrl+N" Click="NewProgram_Click"/>
                            <MenuItem Header="Open..." InputGestureText="Ctrl+O"/>
                            <MenuItem Header="Save" InputGestureText="Ctrl+S" Click="SaveProgram_Click"/>
                            <MenuItem Header="Export..." />
                            <Separator/>
                            <MenuItem Header="Exit" Click="Exit_Click"/>
                        </MenuItem>
                        <MenuItem Header="Edit">
                            <MenuItem Header="Undo" InputGestureText="Ctrl+Z"/>
                            <MenuItem Header="Redo" InputGestureText="Ctrl+Y"/>
                            <Separator/>
                            <MenuItem Header="Cut" InputGestureText="Ctrl+X"/>
                            <MenuItem Header="Copy" InputGestureText="Ctrl+C"/>
                            <MenuItem Header="Paste" InputGestureText="Ctrl+V"/>
                        </MenuItem>
                        <MenuItem Header="Simulation">
                            <MenuItem Header="Run" InputGestureText="F5" Click="Run_Click"/>
                            <MenuItem Header="Pause" Click="Pause_Click"/>
                            <MenuItem Header="Stop" InputGestureText="Shift+F5" Click="Stop_Click"/>
                            <Separator/>
                            <MenuItem Header="Step Into" InputGestureText="F11"/>
                        </MenuItem>
                        <MenuItem Header="Deploy">
                            <MenuItem Header="Deploy to Controller"/>
                            <MenuItem Header="Verify Connection"/>
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem Header="Toggle Properties" Click="ToggleProperties_Click"/>
                            <MenuItem Header="Toggle Console" Click="ToggleConsole_Click"/>
                        </MenuItem>
                    </Menu>

                    <!-- Window Controls -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,4,0" VerticalAlignment="Center">
                        <Button Content="─" Click="Minimize_Click" Style="{StaticResource GlassButton}" Padding="8,2" FontSize="10" Background="Transparent" BorderThickness="0"/>
                        <Button Content="□" Click="Maximize_Click" Style="{StaticResource GlassButton}" Padding="8,2" FontSize="10" Background="Transparent" BorderThickness="0"/>
                        <Button Content="✕" Click="Close_Click" Style="{StaticResource GlassButton}" Padding="8,2" FontSize="10" Background="Transparent" BorderThickness="0"/>
                    </StackPanel>

                    <!-- Mode Toggle -->
                    <Border DockPanel.Dock="Right" Background="{StaticResource Bg.Panel}" CornerRadius="4" Padding="2" Margin="8,2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ModeEdit" Content="Edit" Style="{StaticResource ModeToggle}" IsChecked="True" GroupName="OpMode" Click="ModeEdit_Click"/>
                            <RadioButton x:Name="ModeSimulate" Content="Simulate" Style="{StaticResource ModeToggle}" GroupName="OpMode" Click="ModeSimulate_Click"/>
                            <RadioButton x:Name="ModeLive" Content="Live" Style="{StaticResource ModeToggle}" GroupName="OpMode" Click="ModeLive_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Status Indicator -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Ellipse x:Name="StatusLed" Style="{StaticResource StatusLedOn}"/>
                        <TextBlock x:Name="StatusText" Text="Connected" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>

                <!-- ── Ribbon Toolbar ── -->
                <Border Grid.Row="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,1,0,0">
                    <DockPanel LastChildFill="False" Margin="8,0">
                        <!-- File Group -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,16,0">
                            <Button Style="{StaticResource RibbonButton}" Click="NewProgram_Click" ToolTip="New Program">
                                <StackPanel><TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="New" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Open">
                                <StackPanel><TextBlock Text="📂" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Open" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" Click="SaveProgram_Click" ToolTip="Save">
                                <StackPanel><TextBlock Text="💾" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Save" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Export">
                                <StackPanel><TextBlock Text="📤" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Export" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource Border.Default}" Margin="4,6"/>

                        <!-- Edit Group -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="4,0,16,0">
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Undo">
                                <StackPanel><TextBlock Text="↩" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Undo" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Redo">
                                <StackPanel><TextBlock Text="↪" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Redo" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Cut">
                                <StackPanel><TextBlock Text="✂" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Cut" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Copy">
                                <StackPanel><TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Copy" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Paste">
                                <StackPanel><TextBlock Text="📌" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Paste" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource Border.Default}" Margin="4,6"/>

                        <!-- Execution Group -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="4,0,16,0">
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Compile">
                                <StackPanel><TextBlock Text="🔨" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Compile" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button x:Name="BtnRun" Style="{StaticResource RibbonButton}" Click="Run_Click" ToolTip="Run Program (F5)">
                                <StackPanel><TextBlock Text="▶" FontSize="18" HorizontalAlignment="Center" Foreground="{StaticResource Status.Ok}"/><TextBlock Text="Run" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button x:Name="BtnPause" Style="{StaticResource RibbonButton}" Click="Pause_Click" ToolTip="Pause">
                                <StackPanel><TextBlock Text="⏸" FontSize="18" HorizontalAlignment="Center" Foreground="{StaticResource Status.Warning}"/><TextBlock Text="Pause" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button x:Name="BtnStop" Style="{StaticResource RibbonButton}" Click="Stop_Click" ToolTip="Stop (Shift+F5)">
                                <StackPanel><TextBlock Text="⏹" FontSize="18" HorizontalAlignment="Center" Foreground="{StaticResource Status.Error}"/><TextBlock Text="Stop" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonButton}" ToolTip="Step Into (F11)">
                                <StackPanel><TextBlock Text="⏭" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Step" HorizontalAlignment="Center"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 1: MAIN CONTENT                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>   <!-- Left Sidebar Icons -->
                <ColumnDefinition Width="260"/>  <!-- Left Panel -->
                <ColumnDefinition Width="*"/>    <!-- Center Content -->
                <ColumnDefinition x:Name="PropertiesCol" Width="280"/>  <!-- Properties -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT SIDEBAR (8 Icon Buttons) ── -->
            <Border Grid.Column="0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,8">
                    <RadioButton x:Name="NavProgram" Style="{StaticResource SidebarButton}" GroupName="Nav" IsChecked="True" Click="Nav_Click" Tag="program">
                        <TextBlock Text="📜" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="blocks">
                        <TextBlock Text="🧩" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="motion">
                        <TextBlock Text="🎯" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="io">
                        <TextBlock Text="⚡" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="debug">
                        <TextBlock Text="🔍" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="config">
                        <TextBlock Text="🤖" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="settings">
                        <TextBlock Text="⚙" FontSize="18"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click" Tag="project">
                        <TextBlock Text="📁" FontSize="18"/>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ── LEFT PANEL (Switchable Content) ── -->
            <Border Grid.Column="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,1,0">
                <Grid>
                    <!-- PROGRAM TREE -->
                    <Grid x:Name="PanelProgram" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="PROGRAM TREE" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <TreeView x:Name="ProgramTree" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text.Primary}" Padding="4">
                            <TreeViewItem Header="▼ Main Program" IsExpanded="True" Foreground="{StaticResource Text.Primary}">
                                <TreeViewItem Header="  ▷ Initialize" Foreground="{StaticResource Text.Secondary}"/>
                                <TreeViewItem Header="▼ PickAndPlace" IsExpanded="True" Foreground="{StaticResource Text.Primary}">
                                    <TreeViewItem Header="  🎯 WP_Approach" Foreground="{StaticResource Text.Secondary}"/>
                                    <TreeViewItem Header="  🎯 WP_Pick" Foreground="{StaticResource Accent.Primary}" IsSelected="True"/>
                                    <TreeViewItem Header="  ⚡ SetDO gripper ON" Foreground="{StaticResource Text.Secondary}"/>
                                    <TreeViewItem Header="  🎯 WP_Place" Foreground="{StaticResource Text.Secondary}"/>
                                    <TreeViewItem Header="  ⚡ SetDO gripper OFF" Foreground="{StaticResource Text.Secondary}"/>
                                </TreeViewItem>
                                <TreeViewItem Header="  🔄 CycleLoop" Foreground="{StaticResource Text.Secondary}"/>
                            </TreeViewItem>
                        </TreeView>
                    </Grid>

                    <!-- BLOCK LIBRARY -->
                    <Grid x:Name="PanelBlocks" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="BLOCK LIBRARY" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,4">
                                <!-- Motion Blocks -->
                                <TextBlock Text="Motion" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="4,8,0,4" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1A2B7DE9" BorderBrush="{StaticResource Block.Move}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="MoveJ">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔀 MoveJ" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Joint interpolation" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1A2B7DE9" BorderBrush="{StaticResource Block.Move}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="MoveL">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="📏 MoveL" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Linear path" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1A2B7DE9" BorderBrush="{StaticResource Block.Move}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="MoveC">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="◜ MoveC" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Circular arc" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1A2B7DE9" BorderBrush="{StaticResource Block.Move}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="MoveAbsJ">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔧 MoveAbsJ" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Absolute joints" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>

                                <!-- Logic Blocks -->
                                <TextBlock Text="Logic" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="4,12,0,4" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1AF59E0B" BorderBrush="{StaticResource Block.Logic}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="IfElse">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔀 If / Else" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Conditional branch" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1AEC4899" BorderBrush="{StaticResource Block.Loop}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="While">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔁 While" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Loop while condition" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1AEC4899" BorderBrush="{StaticResource Block.Loop}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="ForLoop">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔄 For" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Fixed iterations" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>

                                <!-- I/O Blocks -->
                                <TextBlock Text="I/O" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="4,12,0,4" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1A22C55E" BorderBrush="{StaticResource Block.IO}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="SetDO">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="⚡ SetDO" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Digital output" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1A22C55E" BorderBrush="{StaticResource Block.IO}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="GetDI">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="📡 GetDI" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Digital input" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>

                                <!-- Timing Blocks -->
                                <TextBlock Text="Timing" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="4,12,0,4" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1AA78BFA" BorderBrush="{StaticResource Block.Wait}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="Wait">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="⏱ Wait" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Timed delay" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                                <Border Style="{StaticResource BlockItemStyle}" Background="#1AA78BFA" BorderBrush="{StaticResource Block.Wait}" BorderThickness="1"
                                        MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick" Tag="WaitDI">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="⏳ WaitDI" Foreground="{StaticResource Text.Primary}" FontWeight="SemiBold"/><TextBlock Text=" — Wait for input" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/></StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- MOTION PLANNING -->
                    <Grid x:Name="PanelMotion" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="MOTION PLANNING" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <ListBox x:Name="WaypointList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text.Primary}" SelectionChanged="Waypoint_Selected">
                        </ListBox>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8" HorizontalAlignment="Center">
                            <Button Content="+ Add Waypoint" Style="{StaticResource GlassButton}" Click="AddWaypoint_Click" Padding="12,6"/>
                            <Button Content="🗑 Delete" Style="{StaticResource GlassButton}" Click="DeleteWaypoint_Click" Padding="12,6" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- I/O PANEL -->
                    <Grid x:Name="PanelIO" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="I/O CONTROL" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,4">
                                <TextBlock Text="Digital Outputs" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="4,8,0,6" FontWeight="SemiBold"/>
                                <local:IORow x:Name="DO1" Label="DO_01  Gripper" IsOutput="True"/>
                                <local:IORow x:Name="DO2" Label="DO_02  Valve" IsOutput="True"/>
                                <local:IORow x:Name="DO3" Label="DO_03  Clamp" IsOutput="True"/>
                                <local:IORow x:Name="DO4" Label="DO_04  Light" IsOutput="True"/>
                                <TextBlock Text="Digital Inputs" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="4,12,0,6" FontWeight="SemiBold"/>
                                <local:IORow Label="DI_01  Prox Sensor" IsOutput="False"/>
                                <local:IORow Label="DI_02  Limit SW" IsOutput="False"/>
                                <local:IORow Label="DI_03  E-Stop" IsOutput="False"/>
                                <local:IORow Label="DI_04  Part Detect" IsOutput="False"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- DIAGNOSTICS -->
                    <Grid x:Name="PanelDebug" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <DockPanel>
                                <TextBlock Text="DIAGNOSTICS" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                                <Button Content="Run Check" Style="{StaticResource GlassButton}" DockPanel.Dock="Right" Padding="8,2" FontSize="10" Click="RunDiag_Click"/>
                            </DockPanel>
                        </Border>
                        <ListBox x:Name="DiagList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text.Primary}"/>
                    </Grid>

                    <!-- ROBOT CONFIG -->
                    <Grid x:Name="PanelConfig" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="ROBOT CONFIGURATION" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,8">
                                <TextBlock Text="Model" Style="{StaticResource PropertyLabel}"/>
                                <ComboBox x:Name="RobotModelCombo" Background="{StaticResource Bg.Panel}" Margin="0,4,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="FR-6DOF (6-Axis)"/>
                                    <ComboBoxItem Content="IRB 6700 (ABB)"/>
                                    <ComboBoxItem Content="KR 210 (KUKA)"/>
                                    <ComboBoxItem Content="UR10e (Universal)"/>
                                </ComboBox>
                                <TextBlock Text="Payload" Style="{StaticResource PropertyLabel}"/>
                                <TextBlock Text="10 kg" Foreground="{StaticResource Text.Primary}" Margin="0,2,0,8"/>
                                <TextBlock Text="Reach" Style="{StaticResource PropertyLabel}"/>
                                <TextBlock Text="1200 mm" Foreground="{StaticResource Text.Primary}" Margin="0,2,0,8"/>
                                <TextBlock Text="Axes" Style="{StaticResource PropertyLabel}"/>
                                <TextBlock Text="6" Foreground="{StaticResource Text.Primary}" Margin="0,2,0,8"/>
                                <TextBlock Text="Repeatability" Style="{StaticResource PropertyLabel}"/>
                                <TextBlock Text="±0.05 mm" Foreground="{StaticResource Text.Primary}" Margin="0,2,0,12"/>
                                <Button Content="Load URDF..." Style="{StaticResource GlassButton}" Click="LoadURDF_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- SETTINGS -->
                    <Grid x:Name="PanelSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="SETTINGS" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <TabControl Grid.Row="1" Background="Transparent" Foreground="{StaticResource Text.Primary}" Margin="4,4">
                            <TabItem Header="Graphics" Foreground="{StaticResource Text.Secondary}">
                                <StackPanel Margin="8"><TextBlock Text="Render API: DirectX 12" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="FPS Target: 60" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="Quality: High" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="VSync: On" Foreground="{StaticResource Text.Primary}" Margin="0,4"/></StackPanel>
                            </TabItem>
                            <TabItem Header="Limits" Foreground="{StaticResource Text.Secondary}">
                                <StackPanel Margin="8"><TextBlock Text="Max Velocity: 100%" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="Max Acceleration: 80%" Foreground="{StaticResource Text.Primary}" Margin="0,4"/></StackPanel>
                            </TabItem>
                            <TabItem Header="Physics" Foreground="{StaticResource Text.Secondary}">
                                <StackPanel Margin="8"><TextBlock Text="Gravity: -9.81 m/s²" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="Collision: Enabled" Foreground="{StaticResource Text.Primary}" Margin="0,4"/></StackPanel>
                            </TabItem>
                            <TabItem Header="Integration" Foreground="{StaticResource Text.Secondary}">
                                <StackPanel Margin="8"><TextBlock Text="ROS 2 Distro: Humble" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="RMW: CycloneDDS" Foreground="{StaticResource Text.Primary}" Margin="0,4"/><TextBlock Text="MoveIt: Enabled" Foreground="{StaticResource Text.Primary}" Margin="0,4"/></StackPanel>
                            </TabItem>
                        </TabControl>
                    </Grid>

                    <!-- PROJECT MANAGER -->
                    <Grid x:Name="PanelProject" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <TextBlock Text="PROJECT MANAGER" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <ListBox x:Name="ProjectList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text.Primary}"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8" HorizontalAlignment="Center">
                            <Button Content="Open" Style="{StaticResource GlassButton}" Padding="16,6"/>
                            <Button Content="Export" Style="{StaticResource GlassButton}" Padding="16,6" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── CENTER CONTENT ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Center Toolbar -->
                    <RowDefinition Height="*"/>     <!-- Viewport / Editor -->
                </Grid.RowDefinitions>

                <!-- Center Toolbar -->
                <Border Grid.Row="0" Background="{StaticResource Bg.Header}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,0,1" Padding="8,2">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <RadioButton x:Name="TabCode" Content="&lt;/&gt; Code" Style="{StaticResource ModeToggle}" GroupName="CenterView" IsChecked="True" Click="CenterTab_Click" Tag="code"/>
                            <RadioButton x:Name="Tab3D" Content="◈ 3D View" Style="{StaticResource ModeToggle}" GroupName="CenterView" Click="CenterTab_Click" Tag="3d"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="☰ Properties" Style="{StaticResource GlassButton}" Click="ToggleProperties_Click" Padding="8,2" FontSize="10" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Code Editor Panel -->
                <Grid x:Name="CodeEditorArea" Grid.Row="1" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- File Tab -->
                    <Border Grid.Row="0" Background="{StaticResource Bg.Header}" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PickPlace_Main.mod" Foreground="{StaticResource Text.Primary}" FontSize="11"/>
                            <Border Background="{StaticResource Accent.Primary}" CornerRadius="2" Padding="6,1" Margin="8,0,0,0">
                                <TextBlock Text="Script" FontSize="9" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Editor Body -->
                    <RichTextBox x:Name="CodeEditor" Grid.Row="1"
                                 Background="{StaticResource Bg.Code}"
                                 Foreground="{StaticResource Text.Primary}"
                                 FontFamily="{StaticResource Font.Mono}"
                                 FontSize="12"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="12,8"/>
                </Grid>

                <!-- 3D Viewport -->
                <Grid x:Name="Viewport3DArea" Grid.Row="1" Visibility="Collapsed">
                    <helix:HelixViewport3D x:Name="HelixView"
                                           Background="{StaticResource Bg.Deepest}"
                                           ShowCoordinateSystem="True"
                                           ShowViewCube="True"
                                           ZoomExtentsWhenLoaded="True"
                                           RotateAroundMouseDownPoint="True"
                                           IsHeadLightEnabled="True"
                                           MouseDown="HelixView_MouseDown">
                        <helix:DefaultLights/>
                        <helix:GridLinesVisual3D Width="2000" Length="2000" MajorDistance="200" MinorDistance="50"
                                                  Thickness="0.5" Fill="#30FFFFFF"/>
                        <ModelVisual3D x:Name="RobotModelVisual"/>
                    </helix:HelixViewport3D>

                    <!-- Viewport Toolbar Overlay -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8">
                        <Button Content="🔄 Reset" Style="{StaticResource GlassButton}" Click="ResetCamera_Click" Padding="8,4" FontSize="10"/>
                        <Button Content="📍 Points" Style="{StaticResource GlassButton}" Padding="8,4" FontSize="10"/>
                        <Button Content="🔲 Collisions" Style="{StaticResource GlassButton}" Padding="8,4" FontSize="10"/>
                    </StackPanel>

                    <!-- Speed Slider Overlay -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12,0,0,12" Orientation="Horizontal">
                        <TextBlock Text="Speed:" Foreground="{StaticResource Text.Muted}" FontSize="10" VerticalAlignment="Center"/>
                        <Slider x:Name="SpeedSlider" Width="120" Minimum="1" Maximum="200" Value="100" Margin="8,0"/>
                        <TextBlock x:Name="SpeedLabel" Text="100%" Foreground="{StaticResource Text.Primary}" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ── RIGHT PROPERTIES PANEL ── -->
            <Border x:Name="PropertiesPanel" Grid.Column="3" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Default}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PanelHeader}">
                        <TextBlock x:Name="PropHeader" Text="PROPERTIES — WP_Pick" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PropContent" Margin="12,8">
                            <!-- Block Type Header -->
                            <TextBlock x:Name="PropBlockType" Text="MOTION TYPE" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton x:Name="PropMoveJ" Content="MoveJ" Style="{StaticResource ModeToggle}" GroupName="MotionType" IsChecked="True"/>
                                <RadioButton x:Name="PropMoveL" Content="MoveL" Style="{StaticResource ModeToggle}" GroupName="MotionType"/>
                            </StackPanel>

                            <!-- Point Definition Method -->
                            <TextBlock Text="POINT DEFINITION" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,4,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="PointMethodCurrent" Content="Current" Style="{StaticResource ModeToggle}" GroupName="PointMethod" IsChecked="True"/>
                                <RadioButton x:Name="PointMethodManual" Content="X/Y/Z" Style="{StaticResource ModeToggle}" GroupName="PointMethod"/>
                                <RadioButton x:Name="PointMethodViewport" Content="Viewport" Style="{StaticResource ModeToggle}" GroupName="PointMethod"/>
                            </StackPanel>

                            <!-- Position (MM) -->
                            <TextBlock Text="POSITION (MM)" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,4,0,6"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropX" Grid.Row="0" Grid.Column="1" Text="450" Style="{StaticResource PropertyInput}" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropY" Grid.Row="1" Grid.Column="1" Text="200" Style="{StaticResource PropertyInput}" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropZ" Grid.Row="2" Grid.Column="1" Text="300" Style="{StaticResource PropertyInput}" Margin="0,2"/>
                            </Grid>

                            <!-- Orientation -->
                            <TextBlock Text="ORIENTATION (DEG)" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,8,0,6"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Rx" Style="{StaticResource PropertyLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="0" Style="{StaticResource PropertyInput}" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ry" Style="{StaticResource PropertyLabel}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="0" Style="{StaticResource PropertyInput}" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Rz" Style="{StaticResource PropertyLabel}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="0" Style="{StaticResource PropertyInput}" Margin="0,2"/>
                            </Grid>

                            <!-- Speed -->
                            <TextBlock Text="SPEED" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,8,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Velocity" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropSpeed" Grid.Column="1" Text="100" Style="{StaticResource PropertyInput}"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Accel" Style="{StaticResource PropertyLabel}"/>
                                <TextBox Grid.Column="1" Text="50" Style="{StaticResource PropertyInput}"/>
                            </Grid>

                            <!-- Variable Label -->
                            <TextBlock Text="VARIABLE LABEL" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,8,0,6"/>
                            <TextBox x:Name="PropVarLabel" Text="WP_Pick" Style="{StaticResource PropertyInput}" Margin="0,0,0,8"/>
                            <Button Content="💾 Save to Point Database" Style="{StaticResource GlassButton}" Click="SavePoint_Click" HorizontalAlignment="Stretch"/>

                            <!-- Joint Values -->
                            <TextBlock Text="JOINT VALUES (DEG)" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="J1" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ1" Grid.Row="0" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="J2" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ2" Grid.Row="1" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="J3" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ3" Grid.Row="2" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="J4" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ4" Grid.Row="3" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="J5" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ5" Grid.Row="4" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="J6" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ6" Grid.Row="5" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                            </Grid>

                            <Border Height="1" Background="{StaticResource Border.Default}" Margin="0,12"/>
                            <Button Content="▶ Apply &amp; Preview" Style="{StaticResource GlassButton}" Click="ApplyBlock_Click" HorizontalAlignment="Stretch" Margin="0,4"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 2: CONSOLE                                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border x:Name="ConsoleArea" Grid.Row="2" Background="{StaticResource Bg.Console}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,1,0,0" MaxHeight="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource Bg.Header}" Padding="12,4">
                    <DockPanel>
                        <TextBlock Text="CONSOLE OUTPUT" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                        <TextBlock x:Name="ConsoleMsgCount" Text="5 messages" DockPanel.Dock="Right" FontSize="10" Foreground="{StaticResource Text.Muted}"/>
                    </DockPanel>
                </Border>
                <ListBox x:Name="ConsoleList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         FontFamily="{StaticResource Font.Mono}" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
