<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds (WSLg Safe Solid Colors) -->
    <SolidColorBrush x:Key="Bg.Deepest" Color="#111112"/> <!-- 3D Viewport Base -->
    <SolidColorBrush x:Key="Bg.Surface1" Color="#1E1E20"/> <!-- Left/Right/Bottom Docks -->
    <SolidColorBrush x:Key="Bg.Surface2" Color="#2A2A2D"/> <!-- Headers, Active states -->
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Border.Default" Color="#3A3A3D"/>
    <SolidColorBrush x:Key="Border.Highlight" Color="#66FACC15"/> <!-- Glow effect -->
    <SolidColorBrush x:Key="Border.Input" Color="#4A4A4D"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="Text.Primary" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Text.Muted" Color="#94A3B8"/>
    
    <!-- Accents (FR-HMI Branding) -->
    <SolidColorBrush x:Key="Accent.Sim" Color="#3B82F6"/> <!-- Blue -->
    <SolidColorBrush x:Key="Accent.Real" Color="#10B981"/> <!-- Green -->
    <SolidColorBrush x:Key="Accent.Motion" Color="#FACC15"/> <!-- FR-HMI Industrial Gold -->
    <SolidColorBrush x:Key="Accent.Error" Color="#EF4444"/> <!-- Red -->
    
    <!-- Fonts -->
    <FontFamily x:Key="Font.UI">Roboto, Inter, Segoe UI Variable, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">JetBrains Mono, Consolas, monospace</FontFamily>
</ResourceDictionary>
