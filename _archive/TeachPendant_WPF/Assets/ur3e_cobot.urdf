<?xml version="1.0" ?>
<!-- Stylized UR3e-style collaborative robot (Blender aesthetic) -->
<!-- Geometry matches React Three.js prototype: Spheres for joints, Boxes for links -->
<robot name="ur3e_cobot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ======================== MATERIALS ======================== -->
  <material name="Base_Dark">
    <color rgba="0.333 0.333 0.333 1.0"/>
  </material>
  <material name="Joint_Orange">
    <color rgba="1.0 0.549 0.0 1.0"/>
  </material>
  <material name="Arm_Silver">
    <color rgba="0.878 0.878 0.878 1.0"/>
  </material>
  <material name="Gripper_Gray">
    <color rgba="0.533 0.533 0.533 1.0"/>
  </material>

  <!-- ======================== LINKS & JOINTS ======================== -->

  <!-- Base Platform -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0.15 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.4" length="0.3"/>
      </geometry>
      <material name="Base_Dark"/>
    </visual>
  </link>

  <!-- Joint 1: Base Rotation -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28" upper="6.28" effort="330.0" velocity="2.16"/>
  </joint>

  <!-- Shoulder: Sphere joint + Box link going upward -->
  <link name="shoulder_link">
    <!-- Joint sphere -->
    <visual>
      <origin xyz="0 0.1 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.15"/>
      </geometry>
      <material name="Joint_Orange"/>
    </visual>
    <!-- Link 1 arm segment -->
    <visual>
      <origin xyz="0 0.55 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.8 0.15"/>
      </geometry>
      <material name="Arm_Silver"/>
    </visual>
  </link>

  <!-- Joint 2: Shoulder Lift -->
  <joint name="joint_2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0.95 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="330.0" velocity="2.16"/>
  </joint>

  <!-- Upper Arm: Sphere joint + Box link -->
  <link name="upper_arm_link">
    <!-- Joint sphere -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <material name="Joint_Orange"/>
    </visual>
    <!-- Link 2 arm segment -->
    <visual>
      <origin xyz="0 0.4 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.7 0.12"/>
      </geometry>
      <material name="Arm_Silver"/>
    </visual>
  </link>

  <!-- Joint 3: Elbow -->
  <joint name="joint_3" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0.75 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.15"/>
  </joint>

  <!-- Forearm: Sphere joint + Box link + Gripper fingers -->
  <link name="forearm_link">
    <!-- Joint sphere -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="Joint_Orange"/>
    </visual>
    <!-- Link 3 end effector arm -->
    <visual>
      <origin xyz="0 0.25 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.4 0.08"/>
      </geometry>
      <material name="Arm_Silver"/>
    </visual>
    <!-- Gripper finger left -->
    <visual>
      <origin xyz="-0.06 0.5 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.12 0.06"/>
      </geometry>
      <material name="Gripper_Gray"/>
    </visual>
    <!-- Gripper finger right -->
    <visual>
      <origin xyz="0.06 0.5 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.12 0.06"/>
      </geometry>
      <material name="Gripper_Gray"/>
    </visual>
  </link>

</robot>
