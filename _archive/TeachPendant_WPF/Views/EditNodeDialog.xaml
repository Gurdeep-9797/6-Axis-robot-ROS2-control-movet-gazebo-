<Window x:Class="TeachPendant_WPF.Views.EditNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Motion Parameters" Height="380" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg.Deepest}" Foreground="{StaticResource Text.Primary}">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="⚙" Foreground="{StaticResource Palette.Primary.Brand}" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="Instruction Parameters" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Text.Primary}" VerticalAlignment="Center"/>
        </StackPanel>
        
        <Border Grid.Row="1" Background="{StaticResource Bg.Surface2}" CornerRadius="4" Padding="12" Margin="0,0,0,16" BorderBrush="{StaticResource Border.Highlight}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cartesian Target" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="🎯 Record Current Workspace Location" Style="{StaticResource FRButtonStyle}" Foreground="{StaticResource Accent.Motion}" FontWeight="Bold" HorizontalAlignment="Right" Click="RecordPosition_Click"/>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="3" Rows="2">
            <StackPanel Margin="4">
                <TextBlock Text="X (mm)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtX" Background="{StaticResource Bg.Surface1}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Margin="4">
                <TextBlock Text="Y (mm)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtY" Background="{StaticResource Bg.Surface1}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Margin="4">
                <TextBlock Text="Z (mm)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtZ" Background="{StaticResource Bg.Surface1}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Margin="4">
                <TextBlock Text="Rx (deg)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtRx" Background="{StaticResource Bg.Surface1}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Margin="4">
                <TextBlock Text="Ry (deg)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtRy" Background="{StaticResource Bg.Surface1}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4" TextAlignment="Center"/>
            </StackPanel>
            <StackPanel Margin="4">
                <TextBlock Text="Rz (deg)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtRz" Background="{StaticResource Bg.Surface1}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4" TextAlignment="Center"/>
            </StackPanel>
        </UniformGrid>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="4">
                <TextBlock Text="Feed Target (Velocity)" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <ComboBox x:Name="CmbFeed" Background="{StaticResource Bg.Surface2}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4">
                    <ComboBoxItem Content="Max Velocity (VMAX)"/>
                    <ComboBoxItem Content="Fast (F100)"/>
                    <ComboBoxItem Content="Standard (F50)" IsSelected="True"/>
                    <ComboBoxItem Content="Slow (F10)"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4">
                <TextBlock Text="Motion Smoothing" Foreground="{StaticResource Text.Muted}" FontSize="11" Margin="0,0,0,2"/>
                <ComboBox x:Name="CmbBlend" Background="{StaticResource Bg.Surface2}" Foreground="{StaticResource Text.Primary}" BorderBrush="{StaticResource Border.Input}" Padding="4">
                    <ComboBoxItem Content="Fine (Exact Stop)" IsSelected="True"/>
                    <ComboBoxItem Content="Continuous (CNT50)"/>
                    <ComboBoxItem Content="Continuous Max (CNT100)"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="4" Height="1" Fill="{StaticResource Border.Default}" VerticalAlignment="Bottom" Margin="0,0,0,16"/>

        <Grid Grid.Row="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="32" Margin="0,0,10,0" Style="{StaticResource FRButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Confirm Entry" Width="120" Height="32" Foreground="{StaticResource Accent.Real}" Style="{StaticResource FRButtonStyle}" Click="Save_Click"/>
            </StackPanel>
            
            <TextBox x:Name="RawOutputTxt" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
