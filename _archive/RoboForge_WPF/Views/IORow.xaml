<UserControl x:Class="RoboForge_WPF.Views.IORow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,4">
    <Grid Background="#1A22C55E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0" Width="8" Background="{StaticResource Bg.Panel}" Margin="0,0,8,0"/>
        
        <TextBlock x:Name="LabelText" Grid.Column="1" Text="DO_01" Foreground="{StaticResource Text.Primary}" VerticalAlignment="Center" Margin="8,8"/>
        
        <!-- Toggle button for Output -->
        <ToggleButton x:Name="ToggleBtn" Grid.Column="2" Width="40" Height="20" Margin="8,0" Visibility="Collapsed" Click="ToggleBtn_Click">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bg" Background="{StaticResource Bg.Panel}" CornerRadius="10" BorderBrush="{StaticResource Border.Default}" BorderThickness="1">
                        <Ellipse x:Name="thumb" Width="16" Height="16" Fill="{StaticResource Text.Muted}" HorizontalAlignment="Left" Margin="2,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#1A22C55E"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource Led.On}"/>
                            <Setter TargetName="thumb" Property="Fill" Value="{StaticResource Led.On}"/>
                            <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="thumb" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#22C55E" BlurRadius="6" Opacity="0.6" ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>
        
        <!-- Status indicator for Input -->
        <Ellipse x:Name="Indicator" Grid.Column="2" Style="{StaticResource StatusLedOff}" Margin="16,0" Visibility="Visible"/>
    </Grid>
</UserControl>
