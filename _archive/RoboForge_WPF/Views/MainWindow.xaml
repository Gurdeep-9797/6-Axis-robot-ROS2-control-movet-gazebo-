<Window x:Class="RoboForge_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        Title="RoboForge — Industrial Robot Programming IDE"
        Width="1440" Height="900" MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{StaticResource Bg.Deepest}" Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.UI}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ ROW 0: TOP RIBBON ══ -->
        <Border Grid.Row="0" Background="{StaticResource Bg.Ribbon}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Height="40">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Accent.Primary}"/>
                    <TextBlock Text="RoboForge" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource Accent.Primary}"/>
                </StackPanel>
                <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="{StaticResource Text.Secondary}" FontSize="12" Margin="8,0" VerticalAlignment="Center">
                    <MenuItem Header="File" Padding="8,4">
                        <MenuItem Header="New Program" InputGestureText="Ctrl+N" Click="NewProgram_Click"/>
                        <MenuItem Header="Open..." InputGestureText="Ctrl+O"/>
                        <MenuItem Header="Save" InputGestureText="Ctrl+S" Click="SaveProgram_Click"/>
                        <MenuItem Header="Export..."/><Separator/>
                        <MenuItem Header="Exit" Click="Exit_Click"/>
                    </MenuItem>
                    <MenuItem Header="Edit" Padding="8,4">
                        <MenuItem Header="Undo" InputGestureText="Ctrl+Z"/>
                        <MenuItem Header="Redo" InputGestureText="Ctrl+Y"/><Separator/>
                        <MenuItem Header="Cut" InputGestureText="Ctrl+X"/>
                        <MenuItem Header="Copy" InputGestureText="Ctrl+C"/>
                        <MenuItem Header="Paste" InputGestureText="Ctrl+V"/>
                    </MenuItem>
                    <MenuItem Header="Simulation" Padding="8,4">
                        <MenuItem Header="Run" InputGestureText="F5" Click="Run_Click"/>
                        <MenuItem Header="Pause" Click="Pause_Click"/>
                        <MenuItem Header="Stop" InputGestureText="Shift+F5" Click="Stop_Click"/>
                    </MenuItem>
                    <MenuItem Header="View" Padding="8,4">
                        <MenuItem Header="Toggle Properties" Click="ToggleProperties_Click"/>
                        <MenuItem Header="Toggle Console" Click="ToggleConsole_Click"/>
                    </MenuItem>
                </Menu>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="12,0">
                    <Button Style="{StaticResource RibbonButton}" Click="NewProgram_Click" ToolTip="New"><Image Source="{StaticResource Icon.New}" Width="16" Height="16" Stretch="Uniform"/></Button>
                    <Button Style="{StaticResource RibbonButton}" ToolTip="Open"><Image Source="{StaticResource Icon.Open}" Width="16" Height="16" Stretch="Uniform"/></Button>
                    <Button Style="{StaticResource RibbonButton}" Click="SaveProgram_Click" ToolTip="Save"><Image Source="{StaticResource Icon.Database}" Width="16" Height="16" Stretch="Uniform"/></Button>
                    <Border Width="1" Background="{StaticResource Border.Light}" Margin="6,8"/>
                    <Button Style="{StaticResource RibbonButton}" ToolTip="Undo"><Image Source="{StaticResource Icon.Undo}" Width="16" Height="16"/></Button>
                    <Button Style="{StaticResource RibbonButton}" ToolTip="Redo"><Image Source="{StaticResource Icon.Redo}" Width="16" Height="16"/></Button>
                    <Border Width="1" Background="{StaticResource Border.Light}" Margin="6,8"/>
                    <Button Style="{StaticResource RibbonButton}" ToolTip="Compile"><Image Source="{StaticResource Icon.Compile}" Width="16" Height="16"/></Button>
                    <Button x:Name="BtnRun" Style="{StaticResource RibbonButton}" Click="Run_Click" ToolTip="Run"><Image Source="{StaticResource Icon.Run}" Width="16" Height="16"/></Button>
                    <Button x:Name="BtnPause" Style="{StaticResource RibbonButton}" Click="Pause_Click" ToolTip="Pause"><Image Source="{StaticResource Icon.Pause}" Width="16" Height="16"/></Button>
                    <Button x:Name="BtnStop" Style="{StaticResource RibbonButton}" Click="Stop_Click" ToolTip="Stop"><Image Source="{StaticResource Icon.Stop}" Width="16" Height="16"/></Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Stretch">
                    <Button Content="─" Click="Minimize_Click" Style="{StaticResource GlassButton}" Padding="12,0" FontSize="10" Background="Transparent" BorderThickness="0"/>
                    <Button Content="□" Click="Maximize_Click" Style="{StaticResource GlassButton}" Padding="12,0" FontSize="10" Background="Transparent" BorderThickness="0"/>
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource GlassButton}" Padding="12,0" FontSize="10" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="{StaticResource Bg.Panel}" CornerRadius="12" Padding="2" Margin="0,6,16,6" BorderBrush="{StaticResource Border.Default}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ModeEdit" Content="Edit" Style="{StaticResource ModeToggle}" IsChecked="True" GroupName="OpMode" Click="ModeEdit_Click"/>
                        <RadioButton x:Name="ModeSimulate" Content="Simulate" Style="{StaticResource ModeToggle}" GroupName="OpMode" Click="ModeSimulate_Click"/>
                        <RadioButton x:Name="ModeLive" Content="Live" Style="{StaticResource ModeToggle}" GroupName="OpMode" Click="ModeLive_Click"/>
                    </StackPanel>
                </Border>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Ellipse x:Name="StatusLed" Width="8" Height="8" Fill="{StaticResource Status.Ok}"/>
                    <TextBlock x:Name="StatusText" Text="Connected" FontSize="10" Foreground="{StaticResource Text.Muted}" Margin="6,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ ROW 1: MAIN CONTENT ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT SIDEBAR (Icon Nav) ── -->
            <Border Grid.Column="0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,8">
                    <RadioButton Tag="program" Content="📋" ToolTip="Program" Style="{StaticResource SidebarButton}" IsChecked="True" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="blocks" Content="🧩" ToolTip="Blocks" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="motion" Content="🎯" ToolTip="Motion" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="io" Content="⚡" ToolTip="I/O" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="debug" Content="🔍" ToolTip="Debug" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="config" Content="🔧" ToolTip="Config" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="settings" Content="⚙" ToolTip="Settings" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="project" Content="📁" ToolTip="Project" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                    <RadioButton Tag="jog" Content="🎮" ToolTip="Jog" Style="{StaticResource SidebarButton}" GroupName="Nav" Click="Nav_Click"/>
                </StackPanel>
            </Border>

            <!-- ── LEFT PANEL (Content Router) ── -->
            <Border Grid.Column="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,1,0">
                <Grid>
                    <!-- Program Tree -->
                    <Grid x:Name="PanelProgram" Visibility="Visible">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="PROGRAM TREE" Style="{StaticResource Text.Label}"/></Border>
                        <ListBox x:Name="WaypointList" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="Waypoint_Selected">
                            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" Style="{StaticResource Text.Label}" Margin="8,4"/></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <!-- Blocks Library -->
                    <Grid x:Name="PanelBlocks" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="BLOCKS LIBRARY" Style="{StaticResource Text.Label}"/></Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="MOTION" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <Border Tag="MoveJ" Style="{StaticResource BlockCard}" BorderBrush="{StaticResource Block.Move}" MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick"><TextBlock Text="MoveJ" FontWeight="Bold" Foreground="{StaticResource Block.Move}"/></Border>
                                <Border Tag="MoveL" Style="{StaticResource BlockCard}" BorderBrush="{StaticResource Block.Move}" MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick"><TextBlock Text="MoveL" FontWeight="Bold" Foreground="{StaticResource Block.Move}"/></Border>
                                <TextBlock Text="LOGIC" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                <Border Tag="Wait" Style="{StaticResource BlockCard}" BorderBrush="{StaticResource Block.Logic}" MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick"><TextBlock Text="Wait" FontWeight="Bold" Foreground="{StaticResource Block.Logic}"/></Border>
                                <TextBlock Text="I/O" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                <Border Tag="SetDO" Style="{StaticResource BlockCard}" BorderBrush="{StaticResource Block.IO}" MouseLeftButtonDown="Block_Click" MouseRightButtonDown="Block_RightClick"><TextBlock Text="SetDO" FontWeight="Bold" Foreground="{StaticResource Block.IO}"/></Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    <!-- Motion Planning -->
                    <Grid x:Name="PanelMotion" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="MOTION PLANNING" Style="{StaticResource Text.Label}"/></Border>
                        <StackPanel Grid.Row="1" Margin="12">
                            <TextBlock Text="Waypoints" FontSize="11" Foreground="{StaticResource Accent.Primary}" FontWeight="SemiBold"/>
                            <Button Content="+ Add Waypoint" Style="{StaticResource GlassButton}" Click="AddWaypoint_Click" Margin="0,8"/>
                            <Button Content="− Delete Selected" Style="{StaticResource GlassButton}" Click="DeleteWaypoint_Click" Margin="0,4"/>
                        </StackPanel>
                    </Grid>
                    <!-- I/O Panel -->
                    <Grid x:Name="PanelIO" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="I/O MONITOR" Style="{StaticResource Text.Label}"/></Border>
                        <StackPanel Grid.Row="1" Margin="12"><TextBlock Text="Digital I/O channels" Style="{StaticResource Text.Label}"/></StackPanel>
                    </Grid>
                    <!-- Debug Panel -->
                    <Grid x:Name="PanelDebug" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="DIAGNOSTICS" Style="{StaticResource Text.Label}"/></Border>
                        <StackPanel Grid.Row="1" Margin="12">
                            <Button Content="Run Diagnostics" Style="{StaticResource GlassButton}" Click="RunDiag_Click"/>
                        </StackPanel>
                    </Grid>
                    <!-- Config Panel -->
                    <Grid x:Name="PanelConfig" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="ROBOT CONFIG" Style="{StaticResource Text.Label}"/></Border>
                        <StackPanel Grid.Row="1" Margin="12"><TextBlock Text="Robot: UR3e Cobot" Style="{StaticResource Text.Label}"/></StackPanel>
                    </Grid>
                    <!-- Settings Panel -->
                    <Grid x:Name="PanelSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="SETTINGS" Style="{StaticResource Text.Label}"/></Border>
                        <StackPanel Grid.Row="1" Margin="12">
                            <Button Content="Load URDF..." Style="{StaticResource GlassButton}" Click="LoadURDF_Click"/>
                        </StackPanel>
                    </Grid>
                    <!-- Project Panel -->
                    <Grid x:Name="PanelProject" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="PROJECT MANAGER" Style="{StaticResource Text.Label}"/></Border>
                        <ListBox x:Name="ProjectList" Grid.Row="1" Background="Transparent" BorderThickness="0"/>
                    </Grid>
                    <!-- Jog Panel -->
                    <Grid x:Name="PanelJog" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}"><TextBlock Text="JOG CONTROL" Style="{StaticResource Text.Label}"/></Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                    <RadioButton Content="1°" GroupName="JogStep" IsChecked="True" Foreground="{StaticResource Text.Secondary}" Margin="0,0,8,0"/>
                                    <RadioButton Content="0.1°" GroupName="JogStep" Foreground="{StaticResource Text.Secondary}" Margin="0,0,8,0"/>
                                    <RadioButton Content="10°" GroupName="JogStep" Foreground="{StaticResource Text.Secondary}"/>
                                </StackPanel>
                                <ItemsControl x:Name="JogJointsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/><ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource Accent.Primary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="−" Tag="{Binding Name}" Click="JogMinus_Click" Style="{StaticResource GlassButton}" Padding="2" FontSize="10"/>
                                                <Slider Grid.Column="2" Minimum="{Binding Min}" Maximum="{Binding Max}" Value="{Binding Value, Mode=TwoWay}" ValueChanged="JogSlider_ValueChanged" Margin="4,0"/>
                                                <Button Grid.Column="3" Content="+" Tag="{Binding Name}" Click="JogPlus_Click" Style="{StaticResource GlassButton}" Padding="2" FontSize="10"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Value, StringFormat=F1}" Foreground="{StaticResource Text.Secondary}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Zero All Joints" Style="{StaticResource GlassButton}" Click="ZeroJoints_Click" Margin="0,12,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- ══ CENTER CONTENT ══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Center Toolbar -->
                <Border Grid.Row="0" Background="{StaticResource Bg.Header}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,0,0,1" Padding="8,2">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <ToggleButton x:Name="TabCode" Content="&lt;/&gt; Code" Background="Transparent" Foreground="{StaticResource Accent.Primary}" IsChecked="True" Click="CenterTab_Click" Tag="code" Padding="8,4" Margin="0,0,4,0"/>
                            <ToggleButton x:Name="Tab3D" Content="◈ 3D View" Background="Transparent" Foreground="{StaticResource Accent.Primary}" IsChecked="True" Click="CenterTab_Click" Tag="3d" Padding="8,4" Margin="0,0,4,0"/>
                            <ToggleButton x:Name="TabPipeline" Content="⟿ Pipeline" Background="Transparent" Foreground="{StaticResource Text.Secondary}" Click="CenterTab_Click" Tag="pipeline" Padding="8,4"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="☰ Properties" Style="{StaticResource GlassButton}" Click="ToggleProperties_Click" Padding="8,2" FontSize="10" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Split Pane Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ColCode" Width="4*"/>
                        <ColumnDefinition x:Name="ColSplit1" Width="4"/>
                        <ColumnDefinition x:Name="Col3D" Width="6*"/>
                        <ColumnDefinition x:Name="ColSplit2" Width="0"/>
                        <ColumnDefinition x:Name="ColPipeline" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <!-- Code Editor -->
                    <Grid x:Name="CodeEditorArea" Grid.Column="0">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                            <TextBlock Text="Node-Graph Editor (Visual Programming)" FontWeight="Bold" Foreground="{StaticResource Text.Secondary}"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="NodeCanvasContainer" Background="{StaticResource Bg.Code}">
                                <Canvas Width="1000" Height="1000">
                                    <Border Canvas.Left="50" Canvas.Top="50" Width="120" Background="{StaticResource Glass.Card}" BorderBrush="{StaticResource Border.Glow}" BorderThickness="1" CornerRadius="6" Panel.ZIndex="10">
                                        <StackPanel Margin="8"><TextBlock Text="▶ Start Routine" Foreground="{StaticResource Text.Primary}" FontWeight="Bold"/></StackPanel>
                                    </Border>
                                    <Path Stroke="{StaticResource Accent.Primary}" StrokeThickness="2" Data="M 170,75 C 220,75 220,150 270,150"/>
                                    <Border Canvas.Left="270" Canvas.Top="125" Width="140" Background="{StaticResource Glass.Card}" BorderBrush="{StaticResource Accent.PrimaryDark}" BorderThickness="1" CornerRadius="6" Panel.ZIndex="10">
                                        <StackPanel Margin="8">
                                            <TextBlock Text="MoveJ (Home)" Foreground="{StaticResource Accent.Primary}" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Speed: 1.0 m/s" Style="{StaticResource Text.Label}"/>
                                        </StackPanel>
                                    </Border>
                                    <Path Stroke="{StaticResource Accent.Primary}" StrokeThickness="2" Data="M 410,150 C 460,150 460,100 510,100"/>
                                    <Border Canvas.Left="510" Canvas.Top="75" Width="140" Background="{StaticResource Glass.Card}" BorderBrush="{StaticResource Status.Ok}" BorderThickness="1" CornerRadius="6" Panel.ZIndex="10">
                                        <StackPanel Margin="8">
                                            <TextBlock Text="SetDO: GrpOpen" Foreground="{StaticResource Status.Ok}" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Value: HIGH" Style="{StaticResource Text.Label}"/>
                                        </StackPanel>
                                    </Border>
                                    <Path Stroke="{StaticResource Accent.Primary}" StrokeThickness="2" Data="M 650,100 C 700,100 700,180 750,180"/>
                                    <Border x:Name="ActiveNodeVisual" Canvas.Left="750" Canvas.Top="155" Width="140" Background="{StaticResource Glass.Card}" BorderBrush="{StaticResource Accent.Primary}" BorderThickness="1" CornerRadius="6" Panel.ZIndex="10">
                                        <StackPanel Margin="8">
                                            <TextBlock Text="MoveL (Approach)" Foreground="{StaticResource Accent.Primary}" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Speed: 0.2 m/s" Style="{StaticResource Text.Label}"/>
                                        </StackPanel>
                                    </Border>
                                </Canvas>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{StaticResource Bg.Panel}" ShowsPreview="True"/>

                    <!-- 3D Viewport -->
                    <Grid x:Name="Viewport3DArea" Grid.Column="2">
                        <helix:HelixViewport3D x:Name="HelixView" Background="{StaticResource Bg.Deepest}"
                            ShowCoordinateSystem="True" ShowViewCube="True" ZoomExtentsWhenLoaded="True"
                            RotateAroundMouseDownPoint="True" IsHeadLightEnabled="True" MouseDown="HelixView_MouseDown">
                            <ModelVisual3D><ModelVisual3D.Content><AmbientLight Color="#4D4D4D"/></ModelVisual3D.Content></ModelVisual3D>
                            <ModelVisual3D><ModelVisual3D.Content><DirectionalLight Color="#CCCCCC" Direction="-1,-1,-1"/></ModelVisual3D.Content></ModelVisual3D>
                            <ModelVisual3D><ModelVisual3D.Content><PointLight Color="#3B9EFF" Position="-3,2,-3" Range="20" ConstantAttenuation="0.5"/></ModelVisual3D.Content></ModelVisual3D>
                            <helix:GridLinesVisual3D Width="4" Length="4" MajorDistance="0.1" MinorDistance="0.05" Thickness="0.002" Fill="#30FFFFFF"/>
                            <helix:CoordinateSystemVisual3D ArrowLengths="0.2"/>
                            <ModelVisual3D x:Name="RobotModelVisual"/>
                        </helix:HelixViewport3D>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8">
                            <Button Content="🔄 Reset" Style="{StaticResource GlassButton}" Click="ResetCamera_Click" Padding="8,4" FontSize="10"/>
                            <Button Content="📍 Points" Style="{StaticResource GlassButton}" Padding="8,4" FontSize="10"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12,0,0,12" Orientation="Horizontal">
                            <TextBlock Text="Speed:" Foreground="{StaticResource Text.Muted}" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SpeedSlider" Width="120" Minimum="1" Maximum="200" Value="100" Margin="8,0"/>
                            <TextBlock x:Name="SpeedLabel" Text="100%" Foreground="{StaticResource Text.Primary}" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <GridSplitter x:Name="SplitterPipeline" Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{StaticResource Bg.Panel}" Visibility="Collapsed"/>

                    <!-- Pipeline Monitor -->
                    <Grid x:Name="PipelineArea" Grid.Column="4" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Bg.Header}" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PIPELINE MONITOR" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Accent.Primary}"/>
                                <TextBlock x:Name="PipelineStatus" Text="  ● IDLE" FontSize="11" Foreground="{StaticResource Text.Muted}" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource Bg.Code}">
                            <StackPanel Margin="24,16">
                                <TextBlock Text="MESSAGE FLOW" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#1A2B7DE9" BorderBrush="{StaticResource Block.Move}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="🖥 UI LAYER" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Accent.Primary}"/>
                                            <Border Background="{StaticResource Bg.Deepest}" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock x:Name="PipeUiMsg" Text="Waiting..." FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="→" FontSize="22" Foreground="{StaticResource Accent.Primary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Background="#1AF59E0B" BorderBrush="{StaticResource Block.Logic}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="⚡ ROS BRIDGE" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Block.Logic}"/>
                                            <Border Background="{StaticResource Bg.Deepest}" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock x:Name="PipeBridgeMsg" Text="Waiting..." FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="3" Text="→" FontSize="22" Foreground="{StaticResource Accent.Primary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="4" Background="#1AE74C3C" BorderBrush="{StaticResource Block.IO}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="🤖 DRIVER" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Block.IO}"/>
                                            <Border Background="{StaticResource Bg.Deepest}" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock x:Name="PipeDriverMsg" Text="Waiting..." FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="JOINT COMMAND" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,16,0,8"/>
                                <Border Background="{StaticResource Bg.Deepest}" CornerRadius="3" Padding="8">
                                    <TextBlock x:Name="PipeJointMsg" Text="No command sent" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                </Border>
                                <TextBlock Text="TELEMETRY FEEDBACK" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,16,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PipeTelJ1" Grid.Column="0" Text="J1: --" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                    <TextBlock x:Name="PipeTelJ2" Grid.Column="1" Text="J2: --" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                    <TextBlock x:Name="PipeTelJ3" Grid.Column="2" Text="J3: --" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                    <TextBlock x:Name="PipeTelJ4" Grid.Column="3" Text="J4: --" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                    <TextBlock x:Name="PipeTelJ5" Grid.Column="4" Text="J5: --" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                    <TextBlock x:Name="PipeTelJ6" Grid.Column="5" Text="J6: --" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                </Grid>
                                <TextBlock Text="STATISTICS" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,16,0,8"/>
                                <Border Background="{StaticResource Bg.Panel}" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock x:Name="PipeMsgCount" Text="Messages Sent: 0  |  Received: 0" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}"/>
                                        <TextBlock x:Name="PipeLatency" Text="Latency: --ms" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Text.Secondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Console -->
                <Border x:Name="ConsoleArea" Grid.Row="2" Background="{StaticResource Bg.Console}" BorderBrush="{StaticResource Border.Default}" BorderThickness="0,1,0,0">
                    <Grid Height="160">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Bg.Header}" Padding="12,4">
                            <DockPanel>
                                <TextBlock Text="CONSOLE OUTPUT" FontWeight="Bold" FontSize="11" Foreground="{StaticResource Text.Secondary}"/>
                                <TextBlock x:Name="ConsoleMsgCount" Text="0 messages" DockPanel.Dock="Right" FontSize="10" Foreground="{StaticResource Text.Muted}"/>
                            </DockPanel>
                        </Border>
                        <ListBox x:Name="ConsoleList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                                 VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Message}" Style="{StaticResource ConsoleItemStyle}"/></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ RIGHT PROPERTIES PANEL ══ -->
            <Border x:Name="PropertiesPanel" Grid.Column="3" Width="260" Background="{StaticResource Bg.Panel}" BorderThickness="1,0,0,0" BorderBrush="{StaticResource Border.Default}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource PanelHeader}"><TextBlock x:Name="PropHeader" Text="PROPERTIES" FontWeight="Bold" Foreground="{StaticResource Text.Secondary}"/></Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12">
                            <TextBlock Text="VARIABLE" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="PropVarLabel" Text="WP_1" Style="{StaticResource PropertyInput}"/>
                            <TextBlock Text="POINT METHOD" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PointMethodViewport" Content="Viewport" GroupName="PointMethod" IsChecked="True" Foreground="{StaticResource Text.Secondary}" Margin="0,0,12,0"/>
                                <RadioButton x:Name="PointMethodCurrent" Content="Current" GroupName="PointMethod" Foreground="{StaticResource Text.Secondary}"/>
                            </StackPanel>
                            <TextBlock Text="POSITION (mm)" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropX" Grid.Row="0" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropY" Grid.Row="1" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropZ" Grid.Row="2" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                            </Grid>
                            <Button Content="💾 Save Point" Style="{StaticResource GlassButton}" Click="SavePoint_Click" Margin="0,8"/>
                            <Border Height="1" Background="{StaticResource Border.Default}" Margin="0,12"/>
                            <TextBlock Text="JOINT VALUES (°)" FontSize="10" Foreground="{StaticResource Text.Muted}" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="J1" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ1" Grid.Row="0" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="J2" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ2" Grid.Row="1" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="J3" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ3" Grid.Row="2" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="J4" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ4" Grid.Row="3" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="J5" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ5" Grid.Row="4" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="J6" Style="{StaticResource PropertyLabel}"/>
                                <TextBox x:Name="PropJ6" Grid.Row="5" Grid.Column="1" Text="0.0" Style="{StaticResource PropertyInput}" Margin="0,1"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource Border.Default}" Margin="0,12"/>
                            <Button Content="▶ Apply &amp; Preview" Style="{StaticResource GlassButton}" Click="ApplyBlock_Click" HorizontalAlignment="Stretch" Margin="0,4"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
