<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══ DARK PREMIUM GLASS BACKGROUNDS ═══ -->
    <SolidColorBrush x:Key="Bg.Deepest"      Color="#0B0F19"/>
    <SolidColorBrush x:Key="Bg.Panel"        Color="#0D121C"/>
    <SolidColorBrush x:Key="Bg.Sidebar"      Color="#0D121C"/>
    
    <SolidColorBrush x:Key="Bg.Console"      Color="#D90B0F19"/> <!-- Semi-transparent for overlapping -->
    <SolidColorBrush x:Key="Bg.Code"         Color="#0B0F19"/>
    <SolidColorBrush x:Key="Bg.Ribbon"       Color="#111827"/>
    <SolidColorBrush x:Key="Bg.Header"       Color="#111827"/>
    <SolidColorBrush x:Key="Bg.Surface"      Color="#1E293B"/>

    <!-- ═══ ACRYLIC / GLASS BACKGROUNDS ═══ -->
    <SolidColorBrush x:Key="Glass.Panel"     Color="#D90D121C"/>
    <SolidColorBrush x:Key="Glass.Header"    Color="#E6111827"/>
    <SolidColorBrush x:Key="Glass.Sidebar"   Color="#E60D121C"/>

    <SolidColorBrush x:Key="Glass.Button"    Color="#00FFFFFF"/>
    <SolidColorBrush x:Key="Glass.ButtonHover" Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="Glass.Card"      Color="#1AFFFFFF"/>

    <!-- Accent glow without gradient -->
    <SolidColorBrush x:Key="Glass.AccentGlow" Color="#330EA5E9"/>

    <!-- ═══ STRICT BORDERS for Crispness ═══ -->
    <SolidColorBrush x:Key="Border.Default"  Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="Border.Light"    Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="Border.Input"    Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="Border.Glow"     Color="#0EA5E9"/>
    <SolidColorBrush x:Key="Border.Glass"    Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="Border.GlassAccent" Color="#0EA5E9"/>

    <!-- ═══ HIGH CONTRAST TEXT (Crisp White/Gray) ═══ -->
    <SolidColorBrush x:Key="Text.Primary"    Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Text.Secondary"  Color="#CBD5E1"/>
    <SolidColorBrush x:Key="Text.Muted"      Color="#64748B"/>
    <SolidColorBrush x:Key="Text.Inverted"   Color="#0B0F19"/>

    <!-- ═══ PRIMARY ACCENT ═══ -->
    <SolidColorBrush x:Key="Accent.Primary"       Color="#0EA5E9"/>
    <SolidColorBrush x:Key="Accent.PrimaryLight"   Color="#38BDF8"/>
    <SolidColorBrush x:Key="Accent.PrimaryDark"    Color="#0284C7"/>
    <Color x:Key="Accent.Primary.Color">#0EA5E9</Color>

    <LinearGradientBrush x:Key="Accent.Gradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0EA5E9" Offset="0"/>
        <GradientStop Color="#0284C7" Offset="1"/>
    </LinearGradientBrush>

    <!-- ═══ STATUS COLORS ═══ -->
    <SolidColorBrush x:Key="Status.Ok"       Color="#10B981"/> <!-- Emerald -->
    <SolidColorBrush x:Key="Status.Warning"  Color="#F59E0B"/> <!-- Amber -->
    <SolidColorBrush x:Key="Status.Error"    Color="#EF4444"/> <!-- Red -->
    <SolidColorBrush x:Key="Status.Info"     Color="#0EA5E9"/> <!-- Cyan -->

    <!-- ═══ CODE EDITOR ═══ -->
    <SolidColorBrush x:Key="Code.Keyword"    Color="#0EA5E9"/>
    <SolidColorBrush x:Key="Code.String"     Color="#10B981"/>
    <SolidColorBrush x:Key="Code.Comment"    Color="#64748B"/>
    <SolidColorBrush x:Key="Code.Number"     Color="#F59E0B"/>
    <SolidColorBrush x:Key="Code.Function"   Color="#A855F7"/>
    <SolidColorBrush x:Key="Code.LineNum"    Color="#334155"/>

    <!-- ═══ BLOCK TYPE COLORS ═══ -->
    <SolidColorBrush x:Key="Block.Move"      Color="#0284C7"/> <!-- Bright Cyan/Blue -->
    <SolidColorBrush x:Key="Block.Logic"     Color="#F59E0B"/> <!-- Amber -->
    <SolidColorBrush x:Key="Block.IO"        Color="#10B981"/> <!-- Emerald -->
    <SolidColorBrush x:Key="Block.Wait"      Color="#8B5CF6"/> <!-- Vivid Purple -->
    <SolidColorBrush x:Key="Block.Loop"      Color="#E11D48"/> <!-- Ruby Rose -->

    <!-- ═══ LED ═══ -->
    <SolidColorBrush x:Key="Led.On"          Color="#10B981"/>
    <SolidColorBrush x:Key="Led.Off"         Color="#1E293B"/>

    <!-- ═══ CONSOLE ═══ -->
    <SolidColorBrush x:Key="Console.Text"    Color="#10B981"/>
    <SolidColorBrush x:Key="Console.Error"   Color="#EF4444"/>
    <SolidColorBrush x:Key="Console.Warning" Color="#F59E0B"/>

    <!-- ═══ 3D VIEWER ═══ -->
    <SolidColorBrush x:Key="Grid.Major"      Color="#1E293B"/>
    <SolidColorBrush x:Key="Grid.Minor"      Color="#0F172A"/>
    <SolidColorBrush x:Key="Axis.X"          Color="#EF4444"/>
    <SolidColorBrush x:Key="Axis.Y"          Color="#10B981"/>
    <SolidColorBrush x:Key="Axis.Z"          Color="#0EA5E9"/>

    <!-- ═══ FONTS ═══ -->
    <FontFamily x:Key="Font.UI">Segoe UI, Inter, Trebuchet MS, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas, JetBrains Mono, monospace</FontFamily>
</ResourceDictionary>
