<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="irb6700_235">
  <!-- Constants for IRB 6700-235/2.65 -->
  <!-- Using approximate inertias and distances for representation since exact ABB CAD is complex -->
  
  <material name="abb_white">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.2" radius="0.3"/></geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.2" radius="0.3"/></geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="50.0"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
  </link>

  <link name="link_1">
    <visual>
      <geometry><cylinder length="0.5" radius="0.2"/></geometry>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.5" radius="0.2"/></geometry>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="40.0"/>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96" upper="2.96" effort="5000.0" velocity="1.74"/>
    <dynamics damping="50.0" friction="20.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <geometry><box size="0.2 0.2 1.1"/></geometry>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><box size="0.2 0.2 1.1"/></geometry>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="40.0"/>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <inertia ixx="2.0" ixy="0" ixz="0" iyy="2.0" iyz="0" izz="0.5"/>
    </inertial>
  </link>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.2 0 0.5" rpy="0 1.570796327 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.13" upper="1.48" effort="4000.0" velocity="1.57"/>
    <dynamics damping="50.0" friction="20.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <geometry><box size="0.2 0.2 0.2"/></geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><box size="0.2 0.2 0.2"/></geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5"/>
    </inertial>
  </link>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 1.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="1.22" effort="3000.0" velocity="1.57"/>
    <dynamics damping="50.0" friction="20.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <geometry><cylinder length="0.8" radius="0.1"/></geometry>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.8" radius="0.1"/></geometry>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <inertia ixx="0.3" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.2 0 0.2" rpy="0 1.570796327 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-5.23" upper="5.23" effort="1000.0" velocity="2.96"/>
    <dynamics damping="20.0" friction="10.0"/>
  </joint>

  <link name="link_5">
    <visual>
      <geometry><cylinder length="0.2" radius="0.1"/></geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.2" radius="0.1"/></geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.8" rpy="0 -1.570796327 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.26" upper="2.26" effort="800.0" velocity="2.44"/>
    <dynamics damping="20.0" friction="10.0"/>
  </joint>

  <link name="link_6">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="abb_white"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.2" rpy="0 1.570796327 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="500.0" velocity="3.31"/>
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <!-- Dummy tool0 definition -->
  <link name="tool0"/>
  <joint name="joint_6-tool0" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ROS2 Control integration specific to DartSim -->
  <ros2_control name="DartSystem" type="system">
    <hardware>
      <plugin>dart_ros2_control/DartSystem</plugin>
    </hardware>
    <!-- joints -->
    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
